_sort": 0, "post_flair_class": "pence", "id": 8587686, "raw_content": "", "author": "CleanUpPhillyTrump24", "created": 1777411697187, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "War_Hamster", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZaUt6iE.png", "removal_source": "", "link": "https://media.scored.co/post/JZLamKQ53zlp.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/nZvuzReUP84Bfk6H.jpeg", "width": 768, "content-type": "jpeg", "height": 459}], "blurhash": "UBFOcM00Gskp?]E1$#M}0L.7R6xZ58%Ls9jF", "full_resolution": [479, 801]}, "title": "DREAM LARGE", "last_comment_created": 1777417549961, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 3, "score_up": 68, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "\u2728\u00a0\u00a0\u00a0MEME MAGIC\u00a0\u00a0\u00a0\u2728", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASZaW0P2M", "is_twitter": false, "is_admin": false, "score": 25, "suggested_sort": 0, "post_flair_class": "", "id": 8588286, "raw_content": "We need to push for laws to be made to curb outsourcing and offshoring. And for that we need as many people to write to the Senators and Whitehouse and Local Representatives. Write every week !\n\nUnderstand the process:\nOur Emails to Senators > Scanned by interns > Issues that have 100+ emails are highlighted to managers > After review they go to Senators\n\nAn example for corporate greed:\n\nU.S Engr: $100K/year\n\nH1B : $65K/year\n\nOffshore Engr: $12K/year\n\nSolutions:\n\nRevise Tax Forms for corporations, regularize and penalize companies for offshoring/outsourcing jobs away from American Soil\n\nLimit companies on what they can expense, they can only deduct 5% of their total offshore expenses\n\nApply 40% tax on offshore profits\n\nPenalize 10% on Revenue (before expenses are deducted), if company has > 10% resources offshore compared to US workers onshore (in the same department)", "author": "TrumpPatriot84", "created": 1777431260086, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "President Trump.  Offshoring American Jobs MUST be addressed, it's as bad if not worse than H1b, solutions inside.", "last_comment_created": 1777431260085, "content": "<p>We need to push for laws to be made to curb outsourcing and offshoring. And for that we need as many people to write to the Senators and Whitehouse and Local Representatives. Write every week !</p>\n<p>Understand the process:\nOur Emails to Senators &gt; Scanned by interns &gt; Issues that have 100+ emails are highlighted to managers &gt; After review they go to Senators</p>\n<p>An example for corporate greed:</p>\n<p>U.S Engr: $100K/year</p>\n<p>H1B : $65K/year</p>\n<p>Offshore Engr: $12K/year</p>\n<p>Solutions:</p>\n<p>Revise Tax Forms for corporations, regularize and penalize companies for offshoring/outsourcing jobs away from American Soil</p>\n<p>Limit companies on what they can expense, they can only deduct 5% of their total offshore expenses</p>\n<p>Apply 40% tax on offshore profits</p>\n<p>Penalize 10% on Revenue (before expenses are deducted), if company has &gt; 10% resources offshore compared to US workers onshore (in the same department)</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false