st_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASt1MzD3k", "is_twitter": false, "is_admin": false, "score": 59, "suggested_sort": 0, "post_flair_class": "", "id": 8698564, "raw_content": "For a federal judge, the procedure is:\n\nA member of the House of Representatives introduces impeachment articles or a committee begins an inquiry.\n\nThe House investigates the alleged misconduct, then votes on articles of impeachment by simple majority.\n\nIf the House approves, the matter goes to the Senate for a trial.\n\nThe Senate hears evidence and votes; conviction requires a two-thirds majority of senators present.\n\nIf convicted, the judge is removed from office, and the Senate can also bar future federal office in some cases.\n\nWtf is Congress doing? Fucking do something you worthless fucks!", "author": "SpaceWizard", "created": 1782424374542, "profile_picture": "GqbxiuANGq2f", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "sub-collector", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Why the fuck aren't we impeaching the rouge activist judges?", "last_comment_created": 1782443992377, "content": "<p>For a federal judge, the procedure is:</p>\n<p>A member of the House of Representatives introduces impeachment articles or a committee begins an inquiry.</p>\n<p>The House investigates the alleged misconduct, then votes on articles of impeachment by simple majority.</p>\n<p>If the House approves, the matter goes to the Senate for a trial.</p>\n<p>The Senate hears evidence and votes; conviction requires a two-thirds majority of senators present.</p>\n<p>If convicted, the judge is removed from office, and the Senate can also bar future federal office in some cases.</p>\n<p>Wtf is Congress doing? Fucking do something you worthless fucks!</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 11, "score_up": 59, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASt1Mzl9n", "is_twitter": false, "is_admin": false, "score": 38, "suggested_sort": 0, "post_flair_class": "", "id": 8698763, "raw_content": "", "author": "Sunnybats2", "created": 1782432872192, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "HillarysBeaverMunch", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.patriots.win", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASt1Mzl9n.png", "removal_source": "", "link": "https://media.patriots.win/post/tCjYXSPK4SKr.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/Kl9iEoH7i2T6pH6u.jpeg", "width": 443, "content-type": "jpeg", "height": 768}], "blurhash": "U4SF;LDi~W-;RiV[xbofE1WVt7M{IoD%M_M|", "full_resolution": [1871, 1080]}, "title": "What \"Jack Kennedy Schlossberg\" did was genuinely difficult:\r\n\r\nBe the only grandson of JFK, have Nancy Pelosi's endorsement, be able to loan your campaign millions, run in a deep blue NYC district, then lose by 25 points to two candidates.\r\n\r\nHe did, however, beat George Conway.", "last_comment_created": 1782439331394, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 1, "score_up": 38, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, 