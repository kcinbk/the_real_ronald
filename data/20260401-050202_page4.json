.scored.co/preview/1ASZ8KcIGu.png", "removal_source": "", "link": "https://media.scored.co/post/t31xxoV0D3AD.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/pHPYfFWH1DBFQbP6.jpeg", "width": 736, "content-type": "jpeg", "height": 736}], "blurhash": "U7G[WrHlIc58=lK}KaE1V6PE^RIXr1TgZ#Io", "full_resolution": [736, 736]}, "title": "Aid to decoding the main-stream media.", "last_comment_created": 1775007221157, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 53, "score_up": 989, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2039074202628579821", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZ8MsFlg", "is_twitter": true, "is_admin": false, "score": 96, "suggested_sort": 0, "post_flair_class": "", "id": 8527108, "raw_content": "", "author": "kinbergfan", "created": 1775005123246, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "staroframphansbhole", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZ8MsFlg.png", "removal_source": "", "link": "https://twitter.com/realmflynnJR/status/2039074202628579821", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Dear Mr. President,\n\nEx-communicating this guy from your orbit will make your poll numbers increase by 5 maybe 10 points easily.\n\n", "last_comment_created": 1775010639310, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 10, "score_up": 96, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 0, "created": 1774984415000, "id": "2039058543484006885", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1235299656063733760/b1RnM8w3_normal.jpg", "displayName": "Lindsey Graham", "username": "LindseyGrahamSC"}, "content": "If you count on the lazy and biased media to tell you what\u2019s going on in Washington regarding @DHSgov funding, you are making a mistake.\n\nHere\u2019s the reality. The Department of Homeland Security is not being funded and its employees are not being paid because Democrats refuse to", "parentTweet": false, "likes": 830}, "images": false, "linkEmbed": false, "replies": 72, "created": 1774988148000, "id": "2039074202628579821", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1759030811079155712/2Z4Og1d3_normal.jpg", "displayName": "Michael Flynn Jr", "username": "realmflynnJR"}, "content": "Dear Mr. President,\n\nEx-communicating this guy from your orbit will make your poll numbers increase by 5 maybe 10 points easily.", "parentTweet": false, "likes": 1688}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASZ8Kd71I", "is_twitter": false, "is_admin": false, "score": 677, "suggested_sort": 0, "post_flair_class": "", "id": 8525704, "raw_content": "This past Friday, as I'm recovering from double mastectomy, my mom died in the hospital. She had been admitted to the hospital the day before I went in for surgery, was in the hospital for 9 days. On the 9th day the doctors attempted to place stents in her heart which had 4 blockages. She had declined open heart surgery and agreed to this procedure knowing she might not survive it. She was ready. Her last few years of life have been harder than anyone should have to live due to lower back issues. She had essentially been bedridden for the last year. \n\nI feel lost. Over the years I've wondered how I would feel when my mom was gone. I knew it would be hard and it is but I'm comforted that she is no longer in pain.. She did everything she could to help me during my breast cancer treatment, even to the detriment of her own physical health. My mom was always there for me and I will miss her presence until the day I die. \n\nMy family is truly going through some of the worst times in these last few years. Trying times. Difficult to navigate. My faith is tested more and more and with those tests I become more convicted in my faith. \n\nIf you still have your mom hug her every chance you can. When she's gone, you don't get it back. \n\nWhen your family gets hit over and over again, as mine has been, politics no longer matter. Love your family and be with them while you can. ", "author": "ChickNorris", "created": 1774966811159, "profile_picture": "Qe8wSmir2i1S", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "STIDGIT64", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "So my mom died", "last_comment_created": 1775022741628, "content": "<p>This past Friday, as I'm recovering from double mastectomy, my mom died in the hospital. She had been admitted to the hospital the day before I went in for surgery, was in the hospital for 9 days. On the 9th day the doctors attempted to place stents in her heart which had 4 blockages. She had declined open heart surgery and agreed to this procedure knowing she might not survive it. She was ready. Her last few years of life have been harder than anyone should have to live due to lower back issues. She had essentially been bedridden for the last year.</p>\n<p>I feel lost. Over the years I've wondered how I would feel when my mom was gone. I knew it would be hard and it is but I'm comforted that she is no longer in pain.. She did everything she could to help me during my breast cancer treatment, even to the detriment of her own physical health. My mom was always there for me and I will miss her presence until the day I die.</p>\n<p>My family is truly going through some of the worst times in these last few years. Trying times. Difficult to navigate. My faith is tested more and more and with those tests I become more convicted in my faith.</p>\n<p>If you still have your mom hug her every chance you can. When she's gone, you don't get it back.</p>\n<p>When your family gets hit over and over again, as mine has been, politics no longer matter. Love your family and be with them while you can.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 144, "score_up": 677, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZ8Kc1QM", "is_twitter": false, "is_admin": false, "score": 1179, "suggested_sort": 0, "post_flair_class": "yes", "id": 8525396, "raw_content": "", "author": "dirtysanchez69", "created": 1774955828428, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "samgab", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZ8Kc1QM.png", "removal_source": "", "link": "https://media.scored.co/post/CapnhZCsy2p7.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/NG0iogxWTaQ8S8OZ.jpeg", "width": 3