 false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": [{"width": 1012, "heightRatio": 40, "url": "https://pbs.twimg.com/media/HDTI4h5bsAAGi7n.png", "height": 410}, {"width": 1430, "heightRatio": 51, "url": "https://pbs.twimg.com/media/HDTJCw1bMAA9eoE.jpg", "height": 740}, {"width": 588, "heightRatio": 184, "url": "https://pbs.twimg.com/media/HDTJzopbYAAnSYC.jpg", "height": 1082}, {"width": 1726, "heightRatio": 53, "url": "https://pbs.twimg.com/media/HDTKHjNbEAAyvPT.jpg", "height": 930}], "linkEmbed": false, "replies": 206, "created": 1773414041000, "id": "2032471916947345519", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1807813962236645376/li41KShP_normal.jpg", "displayName": "DataRepublican (small r)", "username": "DataRepublican"}, "content": "@RadioFreeTom Hello Professor Nichols,\n\nYou spent twenty-five years at the Naval War College. You taught the officers who would go on to run America's wars. Famously, you never served in any of them.\n\nIn February 2003, you were at your desk in Newport when you wrote this, about Colin Powell\u2019s", "parentTweet": {"quotedTweet": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 0, "created": 1773366167000, "id": "2032271118665396517", "video": {"preview": "https://pbs.twimg.com/amplify_video_thumb/2032268352010530816/img/39Bd-raRoPmaxa1e.jpg", "mpeg": "https://video.twimg.com/amplify_video/2032268352010530816/pl/wltDlAkX4NzzHNsc.m3u8?v=a99", "aspectRatio": [16, 9], "heightRatio": 56, "type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2032268352010530816/vid/avc1/480x270/e-ugOfgq4lgeGTiS.mp4"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1884589488942321664/5iqq-N_3_normal.jpg", "displayName": "Secretary of War Pete Hegseth", "username": "SecWar"}, "content": "Professional Military Education should produce warfighters and leaders\