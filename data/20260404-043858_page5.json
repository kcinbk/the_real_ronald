is_image": true, "comments": 2, "score_up": 37, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZCz0k5v", "is_twitter": false, "is_admin": false, "score": 460, "suggested_sort": 0, "post_flair_class": "", "id": 8533417, "raw_content": "", "author": "redditadminssuckit", "created": 1775226519758, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "djentropyhardcore", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZCz0k5v.png", "removal_source": "", "link": "https://media.scored.co/post/aaaNXwX0SF1S.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/feXJCrIdcXn8Ntrs.jpeg", "width": 768, "content-type": "jpeg", "height": 555}], "blurhash": "UBFYv6^z-@I;00aID%9H9wROxuo$%gs+t8bb", "full_resolution": [1022, 1415]}, "title": "I think JD needs to bring back Elons' genius DOGE kids for his anti- fraud efforts", "last_comment_created": 1775250369461, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 18, "score_up": 460, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASZD098wi", "is_twitter": false, "is_admin": false, "score": 79, "suggested_sort": 0, "post_flair_class": "", "id": 8534460, "raw_content": "I\u2019ll preface this by saying this issue is entirely my fault.\n\nAs we approach Easter, I\u2019ve been doing some reflection on my relationship with God and my faith. I feel like time that could be better suited reading Scripture, praying, and serving my community and family has been lately spent endlessly doomscrolling and absorbing political content, especially in light of what\u2019s going on with Iran. It\u2019s like I\u2019m obsessed, and it\u2019s incredibly disheartening to me (and doubtlessly not good for my mental nor spiritual health).\n\nAs we are all very politically involved by virtue of being here, has anyone else experienced this?\n\nI know the answer is as simple as unplugging and just executing basic self control and balance, but I just wanted to vent and see if other people have felt this way.\n\nThanks, and God bless you all. Be with your families this weekend, and with the Lord.", "author": "ArtOfTheComeback64", "created": 1775260673247, "profile_picture": "lkp24HblE33L", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "ArtOfTheComeback64", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Does anyone else feel like a fixation on politics distracts from your relationship with God?", "last_comment_created": 1775273399935, "content": "<p>I\u2019ll preface this by saying this issue is entirely my fault.</p>\n<p>As we approach Easter, I\u2019ve been doing some reflection on my relationship with God and my faith. I feel like time that could be better suited reading Scripture, praying, and serving my community and family has been lately spent endlessly doomscrolling and absorbing political content, especially in light of what\u2019s going on with Iran. It\u2019s like I\u2019m obsessed, and it\u2019s incredibly disheartening to me (and doubtlessly not good for my mental nor spiritual health).</p>\n<p>As we are all very politically involved by virtue of being here, has anyone else experienced this?</p>\n<p>I know the answer is as simple as unplugging and just executing basic self control and balance, but I just wanted to vent and see if other people have felt this way.</p>\n<p>Thanks, and God bless you all. Be with your families this weekend, and with the Lord.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 29, "score_up": 79, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2039367235698037236", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZCz11TU", "is_twitter": true, "is_admin": false, "score": 346, "suggested_sort": 0, "post_flair_class": "", "id": 8533560, "raw_content": "", "author": "blvntbr", "created": 1775231683722, "profile_picture": "VKosve2FUDhO", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Tacitus1963", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZCz11TU.png", "removal_source": "", "link": "https://twitter.com/kennethschrupp/status/2039367235698037236", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "THE OUTRAGEOUS LEVEL OF FRAUD IN AMERICA IS DIRECTLY THE RESULT OF THE PLAN BY OBAMA AND THE COMMIES TO FORCE THE \"CLOWARD-PIVEN\" FINANCIAL COLLAPSE ON THE AMERICAN ECONOMY.", "last_comment_created": 1775262587053, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 6, "score_up": 346, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": {"quotedTweet": fal