79778", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsiTDxaf", "is_twitter": true, "is_admin": false, "score": 178, "suggested_sort": 0, "post_flair_class": "", "id": 8650115, "raw_content": "", "author": "IlhansBrother", "created": 1780195514493, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Tacoboutit", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsiTDxaf.png", "removal_source": "", "link": "https://twitter.com/0xpompadous/status/1942968268366479778", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Paris in the 1980s : ", "last_comment_created": 1780230206445, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 9, "score_up": 178, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": [{"width": 945, "heightRatio": 122, "url": "https://pbs.twimg.com/media/GvbPV7tXIAAvdpM.jpg", "height": 1157}], "linkEmbed": false, "replies": 0, "created": 1752074708000, "id": "1942968268366479778", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1919196102965780480/OeXhaP6m_normal.jpg", "displayName": "Pompadous \ud83c\uddfb\ud83c\udde6", "username": "0xPompadous"}, "content": "Paris in the 80s", "parentTweet": false, "likes": 6}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASsiTEEdl", "is_twitter": false, "is_admin": false, "score": 130, "suggested_sort": 0, "post_flair_class": "", "id": 8650219, "raw_content": "This place was so much better when it was called TheDonald.win.\n\nNow it's just an embarrassment compared to what it was like before.\n\nThis forum was intended to be supportive of Trump, but has almost turned into the opposite and is now almost as hostile to Trump as many leftwing forums. It's one thing to criticize Trump for mistakes and you don't have to agree with him on everything, but now over half the people on this place have turned their backs on him and are vindictive about it to the point they seem to have no problem deliberately letting the left get back into power out of spite, either by sitting out the midterms or voting Democrat with an accelerationist mindset.\n\nThe people on here have become such astounding nihilistic fatalists that I honestly have to question how the fuck y'all live with yourselves. Either you people are beyond miserable inside or you've allowed your nihilism to decay your moral compass and have become psychopaths that just want to see the world burn at this point. Either way, it's disturbing.\n\nI've really been starting to think many of you people actually legitimately don't give a shit about the USA. And you want it to fail just so you can be condescending and say \"I told you so\", and go on an arrogant tirade about how right you were about all of your doomsday predictions.\n\nI can already imagine a bunch of people on here will have self-destructive fatalistic celebrations if the Democrats win the midterms. And I want no fucking part of that.\n\nThe only reason I still spend time here is because there are still some reasonable people here that still act in good faith. Unfortunately that can't be said for over half this forum.", "author": "TheJakeFroggy", "created": 1780201501258, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "DoxProofBro", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "This forum has become a total joke. It's absolutely a shell of its former self.", "last_comment_created": 1780232745847, "content": "<p>This place was so much better when it was called TheDonald.win.</p>\n<p>Now it's just an embarrassment compared to what it was like before.</p>\n<p>This forum was intended to be supportive of Trump, but has almost turned into the opposite and is now almost as hostile to Trump as many leftwing forums. It's one thing to criticize Trump for mistakes and you don't have to agree with him on everything, but now over half the people on this place have turned their backs on him and are vindictive about it to the point they seem to have no problem deliberately letting the left get back into power out of spite, either by sitting out the midterms or voting Democrat with an accelerationist mindset.</p>\n<p>The people on here have become such astounding nihilistic fatalists that I honestly have to question how the fuck y'all live with yourselves. Either you people are beyond miserable inside or you've allowed your nihilism to decay your moral compass and have become psychopaths that just want to see the world burn at this point. Either way, it's disturbing.</p>\n<p>I've really been starting to think many of you people actually legitimately don't give a shit about the USA. And you want it to fail just so you can be condescending and say &quot;I told you so&quot;, and go on an arrogant tirade about how right you were about all of your doomsday predictions.</p>\n<p>I can already imagine a bunch of people on here will have self-destructive fatalistic celebrations if the Democrats win the midterms. And I want no fucking part of that.</p>\n<p>The only reason I still spend time here is because there are still some reasonable people here that still act in good faith. Unfortunately that can't be said for over half this forum.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_s