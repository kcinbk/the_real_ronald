e, "is_admin": false, "score": 98, "suggested_sort": 0, "post_flair_class": "", "id": 8648699, "raw_content": "", "author": "rdvs34283", "created": 1780137059045, "profile_picture": "p9HQtdiLq2uP", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "FreedomLubber", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsdvfGKv.png", "removal_source": "", "link": "https://twitter.com/ScottPresler/status/2060401022162424241", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Our Senate is on vacation AGAIN. By the end of June, it\u2019s another 16-day vacation & Senators don\u2019t work at all in August.", "last_comment_created": 1780152873221, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 2, "score_up": 98, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": [{"width": 1256, "heightRatio": 129, "url": "https://pbs.twimg.com/media/HJgDzz_XkAI7frZ.jpg", "height": 1630}], "linkEmbed": false, "replies": 1255, "created": 1780072858000, "id": "2060401022162424241", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1321124227215491072/pIC0lG5M_normal.jpg", "displayName": "ThePersistence", "username": "ScottPresler"}, "content": "Our Senate is on vacation right now. \n\nThis weekend, they\u2019ll fly back to DC & spend another week finding excuses why they \n\ncan\u2019t pass the SAVE America Act.\n\nBy the end of June, it\u2019s another 16-day vacation & Senators basically don\u2019t work at all in August.", "parentTweet": false, "likes": 16696}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASsdvfoAR", "is_twitter": false, "is_admin": false, "score": 67, "suggested_sort": 0, "post_flair_class": "", "id": 8648857, "raw_content": "\nLast Thursday JD Vance visited Colorado Springs to address the Air Force Academy Cadets at their graduation and nothing was closed down at all. \n\nThe democrats wanted to demonstrate how valuable and important they thought they were by virtually shutting down the entire city when they arrived, like they were kings everyone had to step aside for.  They let us know they were coming by disrupting our lives and restricting our ability to travel in our own city.  The difference is stark. \n\n", "author": "Antero", "created": 1780143921817, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Colorado-Living", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "A few years ago when Biden visited Colorado Springs, they closed down Interstate 25 for hours, dividing the city in half and preventing literally tens of thoudands of people from getting to work on time.  JD Vance just came to Springs and nothing was disrupted. \n", "last_comment_created": 1780146686945, "content": "<p>Last Thursday JD Vance visited Colorado Springs to address the Air Force Academy Cadets at their graduation and nothing was closed down at all.</p>\n<p>The democrats wanted to demonstrate how valuable and important they thought they were by virtually shutting down the entire city when they arrived, like they were kings everyone had to step aside for.  They let us know they were coming by disrupting our lives and restricting our ability to travel in our own city.  The difference is stark.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 1, "score_up": 67, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsdvg5Tz", "is_twitter": false, "is_admin": false, "score": 49, "suggested_sort": 0, "post_flair_class": "", "id": 8648997, "raw_content": "", "author": "TateDemarcus", "created": 1780149948035, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Bjc112", "is_video": false, "video_link": "", "is_new_user": false, "domain": "cdn.5mind.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsdvg5Tz.png", "removal_source": "", "link": "https://cdn.5mind.com/uploads/production/u_PbdG4z7s73aEl_UgSNi/image/EwojOjQ3Vf18-1_a4nbyZ.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/rXTRN7SRQXnMEcGh.jpeg", "width": 619, "content-type": "jpeg", "height": 768}], "blurhash": "USM?J0xZ#*M}~W$zspWXtkM|S%xZ%ONbbHWB", "full_resolution": [894, 720]}, "title": "Guilty as charged. \ud83d\ude4b", "last_comment_created": 1780154891761, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 6, "score_up": 49, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsduX8GP", "is_twitter": false, "is_admin": false, "score": 1016, "suggested_sort": 0, "post_flair_class": "", "id": 8647701, "raw_content": "", "author": "KuzoKevin", "created": 1780090634845, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Tacoboutit", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsduX8GP.png", "removal_source": "", "link": "https://media.scored.co/post/5O0MqihBVgpZ.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/gLEvTUIjp4ci5QzU.jpeg", "width": 641, "content-type": "jpeg", "height": 768}], "blurhash": "UvHB[1WBxaRj~qRjWVWB-;WBofoft7j[a|of", "full_resolution": [1372, 1146]}, "title": "While it violates many aspects of The Geneva Convention.  It just might work.", "last_comment_created": 1780159409283, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 71, "score_up": 1016, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASsdvg511", "is_twitter": false, "is_admin": false, "score": 58, "suggested_sort": 0, "post_flair_class": "", "id": 8648923, "raw_content": "The now infamous Aliens.gov purports 3.12 deportations.  That is largely self deports.  \n\nhttps://cmsny.org/two-million-deportation-myth-ice-enforcement-distorting-data/\n\nUSAFacts.Org:\nRepatriations are executed by both ICE and CBP. CBP repatriation data is not available after 11/2024, but ICE repatriated 319,980 in FY 2025; Between October 2025 and January 2026, ICE removed 144,378 individuals; on pace to reach over 430,000 total removals by the end of FY 2026.\"   You can't divide self deportations and call it a monsterous success.\n\nGoing faster isn't a problem.  There is no will.  Because of the national security emergency, The courts have ruled Posse Commitatus is allowable. So why isnt the military activated?  \n\nUS COURT OF APPEALS FOR THE NINTH CIRCUIT RULED IN FAVOR OF THE EXECUTIVE BRANCH'S EMERGENCY AUTHORITY\u2014TEMPORARILY ALLOWING THE POSSE COMITATUS SUSPENSION TO STAND\u2014NEWSOM V. TRUMP AND THE RECONVENED STATE OF OREGON V. TRUMP. \n\nEven if PC wasnt allowed we are failing: There are 22000 ICE agents.  If 2 agents led a ten man team of 2 local Leo and 6 national guard back up (authorized in PC), that would be 11,000 teams.  Or 110,000 officers.  \nIf each team arrested a conservative 10 people per day (just one person per team member) that would be 110,000 arrests per day.   \n\n220 federal working days per year ( less holidays, weekends, 30 days vacation).  Thats 24,200,000 million ACTUAL deports possible in ICE officers leading teams for a year.\n\nI sent a fleshed out plan based on above, to the WH comms team, office of the Pres, National Security advisor, VP,  State dept and DHS. Going faster isnt a problem. Actually Doing So is.\n\nI didn't include Border Patrol. Or all DHS officers, which totals 80,000.\nNow add military, national guard and a bounty program. \n\n\"ooooo. Look at the doomer.\"  I was 25 yrs USCG. Every person is expected to achieve results. This production is a weak at best.  \"Oh but its better than Biden\" By that standard the Coast Guard could save 10 people and capture 1pound of drugs. But it doesnt.\n\n", "author": "Shitsbrokeyo", "created": 1780146579674, "profile_picture": "Kk8btk4tYuyy", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "barwhack", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Jack shit is happening. Tag me as a Deport Doomer.", "last_comment_created": 1780157242543, "content": "<p>The now infamous Aliens.gov purports 3.12 deportations.  That is largely self deports.</p>\n<p><a rel=\"nofollow\" href=\"https://cmsny.org/two-million-deportation-myth-ice-enforcement-distorting-data/\" target=\"_blank\">https://cmsny.org/two-million-deportation-myth-ice-enforcement-distorting-data/</a></p>\n<p>USAFacts.Org:\nRepatriations are executed by both ICE and CBP. CBP repatriation data is not available after 11/2024, but ICE repatriated 319,980 in FY 2025; Between October 2025 and January 2026, ICE removed 144,378 individuals; on pace to reach over 430,000 total removals by the end of FY 2026.&quot;   You can't divide self deportations and call it a monsterous success.</p>\n<p>Going faster isn't a problem.  There is no will.  Because of the national security emergency, The courts have ruled Posse Commitatus is allowable. So why isnt the military activated?</p>\n<p>US COURT OF APPEALS FOR THE NINTH CIRCUIT RULED IN FAVOR OF THE EXECUTIVE BRANCH'S EMERGENCY AUTHORITY\u2014TEMPORARILY ALLOWING THE POSSE COMITATUS SUSPENSION TO STAND\u2014NEWSOM V. TRUMP AND THE RECONVENED STATE OF OREGON V. TRUMP.</p>\n<p>Even if PC wasnt allowed we are failing: There are 22000 ICE agents.  If 2 agents led a ten man team of 2 local Leo and 6 national guard back up (authorized in PC), that would be 11,000 teams.  Or 110,000 officers.<br />\nIf each team arrested a conservative 10 people per day (just one person per team member) that would be 110,000 arrests per day.</p>\n<p>220 federal working days per year ( less holidays, weekends, 30 days vacation).  Thats 24,200,000 million ACTUAL deports possible in ICE officers leading teams for a year.</p>\n<p>I sent a fleshed out plan based on above, to the WH comms team, office of the Pres, National Security advisor, VP,  State dept and DHS. Going faster isnt a problem. Actually Doing So is.</p>\n<p>I didn't include Border Patrol. Or all DHS officers, which totals 80,000.\nNow add military, national guard and a bounty program.</p>\n<p>&quot;ooooo. Look at the doomer.&quot;  I was 25 yrs USCG. Every person is expected to achieve results. This production is a weak at best.  &quot;Oh but its better than Biden&quot; By that standard the Coast Guard could save 10 people and capture 1pound of drugs. But it doesnt.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 29, "score_up": 58, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsdwm0Un", "is_twitter": false, "is_admin": false, "score": 40, "suggested_sort": 0, "post_flair_class": "", "id": 8649085, "raw_content": "", "author": "TateDemarcus", "created": 1780153729768, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Mungo", "is_video": false, "video_link": "", "is_new_user": false, "domain": "cdn.5mind.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsdwm0Un.png", "removal_source": "", "link": "https://cdn.5mind.com/uploads/production/dEY_W7qlAUpmjNbXrhlQB/image/MVY6Zzw9FCVAmGNCQMRzW.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/WQG9Ax0La2EruuZB.jpeg", "width": 536, "content-type": "jpeg", "height": 768}], "blurhash": "UMHn~c?wIooex^x]oeRjafWCbcxao#WERitR", "full_resolution": [900, 628]}, "title": "\ud83d\ude36\ud83d\udc4d", "last_comment_created": 1780158658354, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 1, "score_up": 40, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2060624566821507549", "sticky_comment": 0, "is_video_mp4": false, "type":