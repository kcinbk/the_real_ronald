media/HLvnWfcWkAAr6i-.jpg", "height": 1350}], "linkEmbed": false, "replies": 0, "created": 1782482175000, "id": "2070506429136490951", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1751624097119768577/6CDEQI9n_normal.jpg", "displayName": "Andrew Hammel", "username": "AndrewHammel1"}, "content": "The cardiac unit of the D\u00fcsseldorf University Hospital, where people recover from heart surgery, is currently measuring 38\u00b0C/ 100.4\u00b0F. As you can see, the building is only about 15 years old. And built without central air-conditioning.", "parentTweet": false, "likes": 5771}, "images": false, "linkEmbed": false, "replies": 188, "created": 1782492613000, "id": "2070550208044253653", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1429915693823242242/l-Ijn1B9_normal.jpg", "displayName": "Megan McArdle", "username": "asymmetricinfo"}, "content": "The fact that Europeans built hospitals without AC is truly mystifying to me. We can argue about whether it's good/necessary in homes, I suppose, but the people in hospitals are the most likely to die of heat stroke!", "parentTweet": false, "likes": 5803}}, "post_flair_text": "", "archive_id": ""}], "status": true}