rsity", "parentTweet": false, "likes": 580}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2079609351338131609", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBzxzqvh", "is_twitter": true, "is_admin": false, "score": 32, "suggested_sort": 0, "post_flair_class": "", "id": 8741141, "raw_content": "", "author": "learntocode", "created": 1784695733071, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Jakylangelo", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBzxzqvh.png", "removal_source": "", "link": "https://twitter.com/HormuzLetter/status/2079609351338131609", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Trump to drop nukes on Iran. ", "last_comment_created": 1784707814341, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 13, "score_up": 32, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 306, "created": 1784652481000, "id": "2079609351338131609", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/2039669923442507776/QiE-cdek_normal.jpg", "displayName": "The Hormuz Letter", "username": "HormuzLetter"}, "content": "BREAKING: Trump announces the US will hit Iran's Pickaxe Mountain nuclear facility \"pretty soon very heavily,\" adding \"there's nothing they can do about it,\" indicating he will use nuclear earth-penetrating bunker busters, as these are the only weapons that can properly destroy", "parentTweet": false, "likes": 4203}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ATBzwsHI2", "is_twitter": false, "is_admin": false, "score": 163, "suggested_sort": 0, "post_flair_class": "", "id": 8740402, "raw_content": "He served in the Navy. I have never been to a funeral with a color guard. It was so beautiful. They played the bugle; they played taps. It brought tears to my eyes. They folded the flag and saluted and brought it to my cousin. He was so kind and he never knew a stranger and always reaching out and making a difference in peoples life because he believed strongly in God and his faith was strong. Always had a smile on his face and was so positive. At the end when he was in the hospice he wore his hat proudly and fearlessly. My faith is in Jesus and my President is Trump wrote across the front of it. He knew that any of those healthcare workers could resent him for that but he did not care because his faith was in God. At the end he did not wish to be resucitated so we brought him home with a nurse where he past away with his loved ones all around and it was peacefully. God bless our veterans and may they all find their way back home to their Father who art in heaven. I will miss you my dear sweet Uncle.", "author": "grannylovestrump", "created": 1784663733090, "profile_picture": "J2VOs7hvr5If", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "USMC4133O7", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "My Uncle was a veteran and we had his memorial today.", "last_comment_created": 1784685394855, "content": "<p>He served in the Navy. I have never been to a funeral with a color guard. It was so beautiful. They played the bugle; they played taps. It brought tears to my eyes. They folded the flag and saluted and brought it to my cousin. He was so kind and he never knew a stranger and always reaching out and making a difference in peoples life because he believed strongly in God and his faith was strong. Always had a smile on his face and was so positive. At the end when he was in the hospice he wore his hat proudly and fearlessly. My faith is in Jesus and my President is Trump wrote across the front of it. He knew that any of those healthcare workers could resent him for that but he did not care because his faith was in God. At the end he did not wish to be resucitated so we brought him home with a nurse where he past away with his loved ones all around and it was peacefully. God bless our veterans and may they all find their way back home to their Father who art in heaven. I will miss you my dear sweet Uncle.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 22, "score_up": 163, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBzwtf8L", "is_twitter": false, "is_admin": false, "score": 47, "suggested_sort": 0, "post_flair_class": "pence", "id": 8740991, "raw_content": "", "author": "CleanUpPhillyTrump24", "created": 1784687901426, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "CleanUpPhillyTrump24", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBzwtf8L.png", "removal_source": "", "link": "https://media.scored.co/post/24Se0yjF9p4v.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/7MeZUShVX38fz2VN.jpeg", "width": 729, "content-type": "jpeg", "height": 500}], 