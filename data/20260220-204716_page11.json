vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 0, "created": 1771613135000, "id": "2024918371880566903", "video": {"preview": "https://pbs.twimg.com/amplify_video_thumb/2024918294806102019/img/5jm8Nsp5Xmn6FPpu.jpg", "mpeg": "https://video.twimg.com/amplify_video/2024918294806102019/pl/ubQ9KdXoWGZJgUHJ.m3u8", "aspectRatio": [16, 9], "heightRatio": 56, "type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2024918294806102019/vid/avc1/480x270/EZLvLtv1D7NEuwhC.mp4"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1937926416563109888/Pbmwqn9W_normal.jpg", "displayName": "First To Hear It", "username": "firsttohearit"}, "content": "TRUMP refuses to take questions from CNN: I don't talk to CNN. It's fake news.", "parentTweet": false, "likes": 3}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASFqqxyJ3", "is_twitter": false, "is_admin": false, "score": 27, "suggested_sort": 0, "post_flair_class": "", "id": 8435135, "raw_content": "If someone becomes a House or Senate member, for the duration of their service that person should have to use a blind trust if their investments exceed $X million. \n\n No family, friends or donors can manage the trust. No third party communication is allowed. That blind trust must be set up in the state from which the person originates. No DC firms.  \n\nThe only communication can be to hire, fire or receive updates. This communication must be fully recorded and attended by a witness.\n\nIf the trust outperforms a set standard, like $Y per term, that automatically triggers an investigation. Members of Congress and their staff cannot share secrets before a bill is publicly voted on in a commission or on the floor. ", "author": "HorrorGameDev", "created": 1771624472956, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Duke442games", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Members of Congress should have to put their investments into blind trusts ", "last_comment_created": 1771629775464, "content": "<p>If someone becomes a House or Senate member, for the duration of their service that person should have to use a blind trust if their investments exceed $X million.</p>\n<p>No family, friends or donors can manage the trust. No third party communication is allowed. That blind trust must be set up in the state from which the person originates. No DC firms.</p>\n<p>The only communication can be to hire, fire or receive updates. This communication must be fully recorded and attended by a witness.</p>\n<p>If the trust outperforms a set standard, like $Y per term, that automatically triggers an investigation. Members of Congress and their staff cannot share secrets before a bill is publicly voted on in a commission or on the floor.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 2, "score_up": 27, "is_edited": true, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASFqqxhSR", "is_twitter": false, "is_admin": false, "score": 30, "suggested_sort": 0, "post_flair_class": "", "id": 8435067, "raw_content": "", "author": "_Liberty_Prime_", "created": 1771622367078, "profile_picture": "evWxa80vv4JN", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "BrokenWolf2022", "is_video": false, "video_link": "", "is_new_user": false, "domain": "