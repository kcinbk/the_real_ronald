 "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASG4xFbG7", "is_twitter": false, "is_admin": false, "score": 19, "suggested_sort": 0, "post_flair_class": "", "id": 8467553, "raw_content": "", "author": "rdvs34283", "created": 1772711494527, "profile_picture": "o9rQiLRpoh9n", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "", "is_video": false, "video_link": "", "is_new_user": false, "domain": "www.city-journal.org", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASG4xFbG7.png", "removal_source": "", "link": "https://www.city-journal.org/article/pennsylvania-permit-license-applications-payback", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Pennsylvania fixes permitting backlog of 2,400 applications that was holding back licenses, construction, housing,& energy projects. They promised to issue permits quickly or give applicants their money back. Agencies required to publish processing times. Backlog is now 0 & other states follow suit.", "last_comment_created": 1772711494527, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 0, "score_up": 19, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"description": "Competition for jobs and investment is pushing states to fix what Washington won\u2019t.", "large_image": "7gIdaX3akYcl8Vnz.png", "title": "Faster Permits\u2014Or Your Money Back? It Worked in Pennsylvania."}, "post_flair_text": "", "archive_id": ""}], "status": true}