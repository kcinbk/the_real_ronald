post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASZD098wi", "is_twitter": false, "is_admin": false, "score": 46, "suggested_sort": 0, "post_flair_class": "", "id": 8534460, "raw_content": "I\u2019ll preface this by saying this issue is entirely my fault.\n\nAs we approach Easter, I\u2019ve been doing some reflection on my relationship with God and my faith. I feel like time that could be better suited reading Scripture, praying, and serving my community and family has been lately spent endlessly doomscrolling and absorbing political content, especially in light of what\u2019s going on with Iran. It\u2019s like I\u2019m obsessed, and it\u2019s incredibly disheartening to me (and doubtlessly not good for my mental nor spiritual health).\n\nAs we are all very politically involved by virtue of being here, has anyone else experienced this?\n\nI know the answer is as simple as unplugging and just executing basic self control and balance, but I just wanted to vent and see if other people have felt this way.\n\nThanks, and God bless you all. Be with your families this weekend, and with the Lord.", "author": "ArtOfTheComeback64", "created": 1775260673247, "profile_picture": "lkp24HblE33L", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "grannyd", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Does anyone else feel like a fixation on politics distracts from your relationship with God?", "last_comment_created": 1775267774124, "content": "<p>I\u2019ll preface this by saying this issue is entirely my fault.</p>\n<p>As we approach Easter, I\u2019ve been doing some reflection on my relationship with God and my faith. I feel like time that could be better suited reading Scripture, praying, and serving my community and family has been lately spent endlessly doomscrolling and absorbing political content, especially in light of what\u2019s going on with Iran. It\u2019s like I\u2019m obsessed, and it\u2019s incredibly disheartening to me (and doubtlessly not good for my mental nor spiritual health).</p>\n<p>As we are all very politically involved by virtue of being here, has anyone else experienced this?</p>\n<p>I know the answer is as simple as unplugging and just executing basic self control and balance, but I just wanted to vent and see if other people have felt this way.</p>\n<p>Thanks, and God bless you all. Be with your families this weekend, and with the Lord.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 25, "score_up": 46, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZCz1ZVR", "is_twitter": false, "is_admin": false, "score": 144, "suggested_sort": 0, "post_flair_class": "", "id": 8533751, "raw_content": "", "author": "Zytos", "created": 1775238357435, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "snoopy3210", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.patriots.win", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZCz1ZVR.png", "removal_source": "", "link": "https://media.patriots.win/post/hDu6efAknDuP.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/MC2C9YMbVy9wuzIg.png", "width": 676, "content-type": "png", "height": 768}], "blurhash": "UsIY5?xu-;xuxuayWVay~qRjRjWBofj[fkWC", "full_resolution": [940, 827]}, "title": "Reddit'