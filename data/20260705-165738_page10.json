k": "", "is_new_user": false, "domain": "www.foxnews.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBlxQ7r1.png", "removal_source": "", "link": "https://www.foxnews.com/health/1776-diet-what-americans-really-ate-during-nations-founding", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "The '1776 Diet': What Americans really ate during the nation's founding", "last_comment_created": 1783268026938, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 21, "score_up": 38, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"description": "Colonial Americans ate whole foods, organ meats and johnnycakes out of necessity. A registered dietician weighs in on what's worth emulating.", "large_image": "m9mfHkT67gb0cW8H.png", "title": "The '1776 Diet': What Americans really ate during the nation's founding"}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBlwIHdD", "is_twitter": false, "is_admin": false, "score": 721, "suggested_sort": 0, "post_flair_class": "", "id": 8713643, "raw_content": "", "author": "DingleBalls", "created": 1783202800077, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "The_Emperor", "is_video": false, "video_link": "", "is_new_user": false, "domain": "nypost.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBlwIHdD.png", "removal_source": "", "link": "https://nypost.com/2026/07/04/us-news/paul-pelosi-charged-with-hit-and-run-in-napa-county/", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Nancy Pelosi\u2019s husband Paul charged with hit-and-run in Napa County", "last_comment_created": 1783260427025, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 53, "score_up": 721, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"description": "Nancy Pelosi\u2019s husband, Paul, is facing hit-and-run charges after allegedly smashing his convertible into a parked car in Napa County before driving off.", "large_image": "Nvtj9hBVKkI8miNm.png", "title": "Nancy Pelosi\u2019s husband Paul charged with hit-and-run in Napa County"}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ATBlxQxXC", "is_twitter": false, "is_admin": false, "score": 14, "suggested_sort": 0, "post_flair_class": "", "id": 8714796, "raw_content": "I always feel like people living in the suburbs who act like the suburbs are some kind of hell on Earth are among the most spoiled and ungrateful people out there. Its like \"oh no, everybody's got a big yard and a big house and they're all families, and there's low crime, and we've all got cars... I'm so miserable!\"\n\nIts like, how spoiled do you have to be to think the suburbs are some kind of terrible place? I mean, I get it if you live in the kind of crappy suburb that is almost like half-urban, half suburb instead of really being a suburb. But usually the people whining about suburbs are people who live in the really nice, sheltered suburbs.\n\nEven if a suburb is \"cookie cutter.\" I still feel like suburban life is just inherently nice.", "author": "MAGA9428", "created": 1783279561282, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "love_laugh_prey", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Pet Peeve of Mine: People Who Whine About Suburbs...", "last_comment_created": 1783285051422, "content": "<p>I always feel like people living in the suburbs who act like the suburbs are some kind of hell on Earth are among the most spoiled and ungrateful people out there. Its like &quot;oh no, everybody's got a big yard and a big house and they're all families, and there's low crime, and we've all got cars... I'm so miserable!&quot;</p>\n<p>Its like, how spoiled do you have to be to think the suburbs are some kind of terrible place? I mean, I get it if you live in the kind of crappy suburb that is almost like half-urban, half suburb instead of really being a suburb. But usually the people whining about suburbs are people who live in the really nice, sheltered suburbs.</p>\n<p>Even if a suburb is &quot;cookie cutter.&quot; I still feel like suburban life is just inherently nice.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 5, "score_up": 14, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}], "status": true}