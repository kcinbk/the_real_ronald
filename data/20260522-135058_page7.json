70/aOeBQ7dlJkI8Hjkb.mp4"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1940339351247851520/Yb99yAbt_normal.jpg", "displayName": "Konstantin Kisin", "username": "KonstantinKisin"}, "content": "What if the west isn't the villain they told you it was?\n\nWe\u2019ve spent years accepting accusations about racism, intolerance, and slavery without challenging the bigger historical reality:\n\nThe societies most condemned today are also the ones that led the world in ending slavery,", "parentTweet": false, "likes": 11085}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASsZ9K24b", "is_twitter": false, "is_admin": false, "score": 43, "suggested_sort": 0, "post_flair_class": "", "id": 8633625, "raw_content": "New York state lawmakers voted Thursday to pass Governor Kathy Hochul\u2019s (D) sweeping Sanctuary State Bill, enacting a broad ban on cooperation between local law enforcement and ICE.\n\nThe radical legislation imposes new restrictions on federal immigration authorities, including barring ICE agents from most public spaces\u2014such as hospitals and parks\u2014and ending 287(g) agreements, which are voluntary partnerships between local law enforcement and federal agents.\n\nIt also bans ICE agents from wearing masks, which would allow them to protect their lives and their families' safety.", "author": "Oldman1234", "created": 1779453534942, "profile_picture": "72nh7uv9BSsD", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "God-is-good", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "New York State passes new law banning state-wide cooperation with ICE.", "last_comment_created": 1779466166753, "content": "<p>New York state lawmakers voted Thursday to pass Governor Kathy Hochul\u2019s (D) sweeping Sanctuary State Bill, enacting a broad ban on cooperation between local law enforcement and ICE.</p>\n<p>The radical legislation imposes new restrictions on federal immigration authorities, including barring ICE agents from most public spaces\u2014such as hospitals and parks\u2014and ending 287(g) agreements, which are voluntary partnerships between local law enforcement and federal agents.</p>\n<p>It also bans ICE agents from wearing masks, which would allow them to protect their lives and their families' safety.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 11, "score_up": 43, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2057483910309683306", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsZ9KJJx", "is_twitter": true, "is_admin": false, "score": 34, "suggested_sort": 0, "post_flair_class": "", "id": 8633751, "raw_content": "", "author": "rdvs34283", "created": 1779457970333, "profile_picture": "p9HQtdiLq2uP", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "FusionBlack", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsZ9KJJx.png", "removal_source": "", "link": "https://twitter.com/asia_decode2/status/2057483910309683306", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Gathering Ingredients", "last_comment_created": 1779459163326, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "co