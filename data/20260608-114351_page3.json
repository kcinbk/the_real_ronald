emoval_source": "", "link": "https://media.scored.co/post/VsUEmIYocZPA.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/EF5jX4QMQAAQVREX.jpeg", "width": 713, "content-type": "jpeg", "height": 768}], "blurhash": "UUBy?pax9Efl%%ayMwj[Ioa}ofj[Z~j[t7fQ", "full_resolution": [778, 722]}, "title": "The Four Senators Of The Apocalypse", "last_comment_created": 1780919554722, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 2, "score_up": 112, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASsnGjmZ5", "is_twitter": false, "is_admin": false, "score": 110, "suggested_sort": 0, "post_flair_class": "", "id": 8666957, "raw_content": "Now we know why California, and LA in particular, has such a strangely hard time dealing with their homeless problem, and why their \"solutions\" always just so happen to attract even more homeless (oopsy).\n\nThey register the homeless so they can use the registration forms to create fake ballots.\n\nI witnessed a version of this at a music festival when I was young. They set up voter registration drives at music festivals because they know youth are much less likely to bother going to the polls on election day, so they can use the registrations for fake votes.\n\nHow likely do you think it is a fentanyl addict on skid row would go to a voting booth or fill out a mail in ballot?", "author": "Herpawinski", "created": 1780915177024, "profile_picture": "GCJCeufYDd47", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Icepck", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "The Pratt situation exposes why California has such a bad homeless problem.", "last_comment_created": 1780927667665, "content": "<p>Now we know why California, and LA in particular, has such a strangely hard time dealing with their homeless problem, and why their &quot;solutions&quot; always just so happen to attract even more homeless (oopsy).</p>\n<p>They register the homeless so they can use the registration forms to create fake ballots.</p>\n<p>I witnessed a version of this at a music festival when I was young. They set up voter registration drives at music festivals because they know youth are much less likely to bother going to the polls on election day, so they can use the registrations for fake votes.</p>\n<p>How likely do you think it is a fentanyl addict on skid row would go to a voting booth or fill out a mail in ballot?</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 8, "score_up": 110, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2063736152545452188", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsnHqFPM", "is_twitter": true, "is_admin": false, "score": 66, "suggested_sort": 0, "post_flair_class": "yes", "id": 8667200, "raw_content": "", "author": "blue5707", "created": 1780925002191, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Spunas1", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsnHqFPM.png", "removal_source": "", "link": "https://twitter.com/SteveInman/status/2063736152545452188?s=20", "author_