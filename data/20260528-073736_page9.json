ent_author": "Finnigantoflannigan", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsdq06gJ.png", "removal_source": "", "link": "https://media.scored.co/post/O4AdfPJHjBtM.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/3eV04cy7tPxksplz.jpeg", "width": 451, "content-type": "jpeg", "height": 680}], "blurhash": "U7IW=j^Kv|~V0LRQe-R%rqa1IpN{0i58E2Nd", "full_resolution": [680, 451]}, "title": "If there is true evil in the world - it is Liberal Catholics.", "last_comment_created": 1779967351182, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 2, "score_up": 52, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASsdr6quG", "is_twitter": false, "is_admin": false, "score": 12, "suggested_sort": 0, "post_flair_class": "", "id": 8644360, "raw_content": "Ohio House Bill 854 proposes to tax high-earning residents to completely fund free college tuition for in-state students. Introduced in May 2026 by Democratic State Representatives Munira Abdullahi and Tristan Rader, the legislation aims to establish the Ohio Free College Fund to eliminate financial barriers to higher education.Key Details of the LegislationFree Tuition Guarantee: The bill mandates that all 14 of Ohio's public universities provide free undergraduate tuition for up to eight semesters to any qualifying in-state resident.The Funding Mechanism: It creates a progressive state income tax tier specifically targeting individuals, trusts, and estates making more than $500,000 annually.Progressive Tax Rates: The new tax applies only to income earned above the baseline:Income between $500,000 and $1 million would be taxed at 5.375%.Income exceeding $1 million would be taxed at 7.375%.Additional Revenue Sources: The text of OH HB 854 on BillTrack50 also outlines a 1% fee on residential property transfers valued over $2 million and a tax on corporate employers for compensation exceeding $10 million annually.Estimated Fiscal ImpactProponents of the bill estimate that roughly 2.38% of Ohio households earn above the $500,000 threshold. Lawmakers project that these changes could generate roughly $3.125 billion annually. Based on current averages for in-state public tuition, this revenue would be sufficient to fund tuition for more than 244,000 students, covering the entire current in-state public university population.Current Status and OutlookThe bill was officially referred to the House Workforce and Higher Education Committee on May 13, 2026, where it awaits its initial hearing dates. Because the Ohio General Assembly holds a firm Republican supermajority, political analysts expect the bill faces incredibly steep hurdles to passing. Critics frequently argue that such measures increase the tax burden, risk driving wealthy residents out of state, and question the overall return on investment compared to funding K-12 systems.", "author": "JustTheNews", "created": 1779963968640, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "NotYourMan", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "2.38% of Ohioians to pay for 100% of Ohios FREE COLLEGE. 3.1 Billion dollars in taxes collected from 2.38%...", "last_comment_created": 1779964982376, "content": "<p>Ohio House Bill 854 proposes to tax high-earning residents to completely fund free college tuition for in-state students. Introduced in May 2026 by Democratic State Representatives Munira Abdullahi and Tristan Rader, the legislation aims to establish the Ohio Free College Fund to eliminate financial barriers to higher education.Key Details of the LegislationFree Tuition Guarantee: The bill mandates that all 14 of Ohio's public universities provide free undergraduate tuition for up to eight semesters to any qualifying in-state resident.The Funding Mechanism: It creates a progressive state income tax tier specifically targeting individuals, trusts, and estates making more than $500,000 annually.Progressive Tax Rates: The new tax applies only to income earned above the baseline:Income between $500,000 and $1 million would be taxed at 5.375%.Income exceeding $1 million would be taxed at 7.375%.Additional Revenue Sources: The text of OH HB 854 on BillTrack50 also outlines a 1% fee on residential property transfers valued over $2 million and a tax on corporate employers for compensation exceeding $10 million annually.Estimated Fiscal ImpactProponents of the bill estimate that roughly 2.38% of Ohio households earn above the $500,000 threshold. Lawmakers project that these changes could generate roughly $3.125 billion annually. Based on current averages for in-state public tuition, this revenue would be sufficient to fund tuition for more than 244,000 students, covering the entire current in-state public university population.Current Status and OutlookThe bill was officially referred to the House Workforce and Higher Education Committee on May 13, 2026, where it awaits its initial hearing dates. Because the Ohio General Assembly holds a firm Republican supermajority, political analysts expect the bill faces incredibly steep hurdles to passing. Critics frequently argue that such measures increase the tax burden, risk driving wealthy residents out of state, and question the overall return on investment compared to funding K-12 systems.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 2, "score_up": 12, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsdr6J0c", "is_twitter": false, "is_admin": false, "score": 28, "suggested_sort": 0, "post_flair_class": "npc", "id": 8644192, "raw_content": "", "author": "Hanging_Chad", "created": 1779947066577, "profile_picture": "GUPKlPiq0RXL", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsdr6J0c.png", "removal_source": "", "link": "https://media.scored.co/post/6BYD2d2YWFcM.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/8FqBHEoSiSO37Saf.jpeg", "width": 512, "content-type": "jpeg", "height": 640}], "blurhash": "UON,f2WCtQf800axM{ay_3oJWXjZ?^a#oLj[", "full_resolution": [640, 512]}, "title": "ChatGPT announced as Harvard valedictorian \ud83d\udc69\ud83c\udffe\u200d\ud83c\udf93\ud83d\udcd1\ud83d\udcdd", "last_comment_created": 1779947066575, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 0, "score_up": 28, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "GRAY LIVES MATTER", "archive_id": ""}, {"is_locked": false, "tweet_id": "2059679204732485661", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsdpz0YH", "is_twitter": true, "is_admin": false, "score": 102, "suggested_sort": 0, "post_flair_class": "illegal", "id": 8643575, "raw_content":