uthor": "UncleRicoAct", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASFqqyFUH.png", "removal_source": "", "link": "https://media.scored.co/post/z1uIWf8wktKs.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/dkPmQyL3lv7Efy29.png", "width": 768, "content-type": "png", "height": 674}], "blurhash": "U9CZhL00048_?]8_=}4.00%hW8-B00~XVYyD", "full_resolution": [807, 919]}, "title": "We are talking about UFOs when we have pedophile cannibals filling the ranks of societal power. Ri-fucking-diculous. I want prosecutions with full treason status. ", "last_comment_created": 1771637912000, "content": "", "score_down": 7, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 22, "score_up": 93, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASFqpqPGY", "is_twitter": false, "is_admin": false, "score": 252, "suggested_sort": 0, "post_flair_class": "", "id": 8434486, "raw_content": "In September\u202f2025, the U.S. government (via a presidential proclamation) introduced a one\u2011time $100,000 payment requirement attached to most new H\u20111B visa petitions for workers outside the United States \u2014 effective Sept\u202f21,\u202f2025. This new requirement will hit employers throughout 2026 and 2027. Employers filing a new H\u20111B petition for a worker outside the U.S. generally must pay a one-time $100,000 fee per petition.\n\nFY\u202f2026: ~336,000 unique beneficiaries (or ~339,000 by some counts)\n\nFY\u202f2025: ~442,000 unique beneficiaries\nSo there was a drop from roughly 442\u202fK down to ~336\u202fK between those two years\n\n\nhttps://www.whitehouse.gov/presidential-actions/2025/09/restriction-on-entry-of-certain-nonimmigrant-workers/\n", "author": "HorrorGameDev", "created": 1771606692800, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Dallasguy", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Trump listened: The H1B program has shrunk 25% for 2026 and employers must pay $100k for new foreign talent. TX has also suspended all new public sector H1B requests. A good start, but keep going. ", "last_comment_created": 1771629009004, "content": "<p>In September\u202f2025, the U.S. government (via a presidential proclamation) introduced a one\u2011time $100,000 payment requirement attached to most new H\u20111B visa petitions for workers outside the United States \u2014 effective Sept\u202f21,\u202f2025. This new requirement will hit employers throughout 2026 and 2027. Employers filing a new H\u20111B petition for a worker outside the U.S. generally must pay a one-time $100,000 fee per petition.</p>\n<p>FY\u202f2026: ~336,000 unique beneficiaries (or ~339,000 by some counts)</p>\n<p>FY\u202f2025: ~442,000 unique beneficiaries\nSo there was a drop from roughly 442\u202fK down to ~336\u202fK between those two years</p>\n<p><a rel=\"nofollow\" href=\"https://www.whitehouse.gov/presidential-actions/2025/09/restriction-on-entry-of-certain-nonimmigrant-workers/\" target=\"_blank\">https://www.whitehouse.gov/presidential-actions/2025/09/restriction-on-entry-of-certain-nonimmigrant-workers/</a></p>\n", "score_down": 1, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 18, "score_up": 253, "is_edited": false, "is_moderator": false, "awards": 0, "vo