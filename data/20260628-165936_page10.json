: false, "is_deleted": false, "is_image": true, "comments": 1, "score_up": 18, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0PEPE\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0", "archive_id": ""}, {"is_locked": false, "tweet_id": "2070997334864134205", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBhEUeFb", "is_twitter": true, "is_admin": false, "score": 43, "suggested_sort": 0, "post_flair_class": "", "id": 8702697, "raw_content": "", "author": "jughaid", "created": 1782654028396, "profile_picture": "4pYeSnRi59MW", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Rango", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBhEUeFb.png", "removal_source": "", "link": "https://twitter.com/Gunblaze1969/status/2070997334864134205?s=20", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "All Bob's Money.   (I will give to you...)", "last_comment_created": 1782657502026, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 2, "score_up": 43, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 5, "created": 1782599216000, "id": "2070997334864134205", "video": {"preview": "https://pbs.twimg.com/amplify_video_thumb/2070997247916130304/img/DNPSNAgfl3qVUwK-.jpg", "mpeg": "https://video.twimg.com/amplify_video/2070997247916130304/pl/QKjumwOkUpQtnSPv.m3u8", "aspectRatio": [16, 9], "heightRatio": 56, "type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2070997247916130304/vid/avc1/480x270/AIMHnXkOSA3rn1QO.mp4"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1529613011492786177/u_JIR6CO_normal.jpg", "displayName": "The Rubber Chicken\ud83c\udde8\ud83c\udde6", "username": "Gunblaze1969"}, "content": "This would be funny were it not true...\ud83e\udd23\ud83d\ude02", "parentTweet": false, "likes": 60}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ATBhEVSnQ", "is_twitter": false, "is_admin": false, "score": 24, "suggested_sort": 0, "post_flair_class": "", "id": 8702900, "raw_content": "hardware needed to intercept their signals. \n\n1. Bluetooth & Item Trackers (AirTags, Tile, etc.)\n\nModern smartphones are excellent at detecting unwanted Bluetooth tracking devices.\n\niPhone: iOS has built-in Tracking Notifications. If an unknown AirTag or Find My accessory is traveling with you, your phone will alert you. You can also force a manual check in the Find My app under the \"Items\" tab.\n\nAndroid: Android phones have an Unknown tracker alerts feature. You can check this by going to Settings > Safety & emergency > Unknown tracker alerts to run manual scans or enable automatic alerts.", "author": "OrangeManNotBad", "created": 1782665296358, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "pasteMiller", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "your cell phone can detect certain types of GPS trackers\u2014specifically Bluetooth trackers (like Apple AirTags) and some real-time devices transmitting Bluetooth or Wi-Fi. However, your phone cannot natively detect traditional cellular-based GPS trackers or passive loggers, as it lacks the specialized", "last_comment_created": 1782669846548, "content": "<p>hardware needed to intercept their signals.</p>\n<ol>\n<li>Bluetooth &amp; Item Trackers (AirTags, Tile, etc.)</li>\n</ol>\n<p>Modern smartphones are excellent at detecting unwanted Bluetooth tracking devices.</p>\n<p>iPhone: iOS has built-in Tracking Notifications. If an unknown AirTag or Find My accessory is traveling with you, your phone will alert you. You can also force a manual check in the Find My app under the &quot;Items&quot; tab.</p>\n<p>Android: Android phones have an Unknown tracker alerts feature. You can check this by going to Settings &gt; Safety &amp; emergency &gt; Unknown tracker alerts to run manual scans or enable automatic alerts.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 2, "score_up": 24, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2070896514524684314", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBhEUupg", "is_twitter": true, "is_admin": false, "score": 39, "suggested_sort": 0, "post_flair_class": "", "id": 8702724, "raw_content": "", "author": "DingleBalls", "created": 1782655678918, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Jakylangelo", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBhEUupg.png", "removal_source": "", "link": "https://twitter.com/JohnCornyn/status/2070896514524684314", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Fucker has no idea what he's talking about", "last_comment_created": 1782673793562, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 10, "score_up": 39, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 7546, "created": 1782575179000, "id": "2070896514524684314", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1932474608675901440/xY6zL55F_normal.jpg", "displayName": "Senator John Cornyn", "username": "JohnCornyn"}, "content": "I marvel at the keyboard warrior-geniuses and grifters who are ignorant of Senate rules and precedents who have miraculously become experts in its arcane rules. Promising the moon and stars and yet destining Republicans for failure is a very effective way to demoralize our base", "parentTweet": false, "likes": 1107}}, "post_flair_text": "", "archive_id": ""}], "status": true}