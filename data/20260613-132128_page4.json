is_deleted": false, "is_image": false, "comments": 4, "score_up": 38, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 0, "created": 1781281457000, "id": "2065470251798614448", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1881455615785988096/nrer-dZk_normal.jpg", "displayName": "Ed Markey", "username": "EdMarkey"}, "content": "Elon Musk just became the world's first trillionaire. While working people struggle to get by, the billionaire class is becoming the TRILLIONAIRE class. It's disgusting. I'm fighting to tax the rich so we stop rewarding trading stocks over punching clocks.", "parentTweet": false, "likes": 629}, "images": false, "linkEmbed": false, "replies": 456, "created": 1781321059000, "id": "2065636354940129345", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/563742870218096640/C76dpIVy_normal.jpeg", "displayName": "US Oil & Gas Association", "username": "US_OGA"}, "content": "Hello Senator....\n\nThis November it will be 50 years since you were first elected to Congress, so we want to be the first to say . \n\n\"Happy 50th Anniversary of drawing a taxpayer funded salary.\"\n\nThat is quite an achievement.\n\nIn fact - you are 2nd longest-still serving member in", "parentTweet": false, "likes": 18067}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2065539834966384991", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsryW2lk", "is_twitter": true, "is_admin": false, "score": 426, "suggested_sort": 0, "post_flair_class": "", "id": 8677418, "raw_content": "", "author": "KuzoKevin", "created": 1781317612320, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Vlad007", "is_video": false, "video_link": "", "is_new_user": false, "domain": 