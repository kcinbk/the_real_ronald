te_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASsUZRW2a", "is_twitter": false, "is_admin": false, "score": 459, "suggested_sort": 0, "post_flair_class": "", "id": 8629078, "raw_content": "It wasn't long ago I made a post on here about my wife and I having difficulty with infertility.  Thank God we found the right doctor who discovered the problem.  We had a healthy girl in 2024, and her sister's on the way tonight.  \n\nFor any of those having similar issues, don't discount thyroid issues, even if a common doctor has said that thyroid is 'normal'.  The thyroid has a lot going on, and most doctors will only measure the surface level readings, the TSH (Thyroid Stimulating Hormone) and say that things are normal, which is misleading.  This is what we were told by idiots who didn't bother looking further.  We met an endocrinologist and integrative medicine doctor who said \"We need to look deeper\".  There can be an imbalance in the T3 to ReverseT3 that can lead to fertility issues.  This is what ended up being my wife's issue.", "author": "Linnaeus", "created": 1779253259729, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "ancroidubh", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "In Jesus\u2019 name, we welcome our new little one with gratitude.   My wife is delivering our second daughter today.  ", "last_comment_created": 1779305540573, "content": "<p>It wasn't long ago I made a post on here about my wife and I having difficulty with infertility.  Thank God we found the right doctor who discovered the problem.  We had a healthy girl in 2024, and her sister's on the way tonight.</p>\n<p>For any of those having similar issues, don't discount thyroid issues, even if a common doctor has said that thyroid is 'normal'.  The thyroid has a lot going on, and most doctors will only measure the surface level readings, the TSH (Thyroid Stimulating Hormone) and say that things are normal, which is misleading.  This is what we were told by idiots who didn't bother looking further.  We met an endocrinologist and integrative medicine doctor who said &quot;We need to look deeper&quot;.  There can be an imbalance in the T3 to ReverseT3 that can lead to fertility issues.  This is what ended up being my wife's issue.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 33, "score_up": 459, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsZ5u1lU", "is_twitter": false, "is_admin": false, "score": 28, "suggested_sort": 0, "post_flair_class": "pocrime", "id": 8630384, "raw_content": "", "author": "TaxDollarsHardAtWork", "created": 1779307902397, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "GoSpeedRacistGo", "is_video": false, "video_link": "", "is_new_user": false, "domain": "justthenews.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsZ5u1lU.png", "removal_source": "", "link": "https://justthenews.com/government/courts-law/pro-dei-prosecutor-charged-over-illegally-emailing-herself-jack-smiths-sealed", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Prosecutor charged for allegedly emailing self sealed Jack Smith Trump report veiled as cake recipes - Jerry Dunleavy", "last_co