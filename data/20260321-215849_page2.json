: 200}, "post_flair_text": "SAVE AMERICA", "archive_id": ""}, {"is_locked": false, "tweet_id": "2035374905298980987", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASYywAVcs", "is_twitter": true, "is_admin": false, "score": 91, "suggested_sort": 0, "post_flair_class": "", "id": 8504876, "raw_content": "", "author": "_Liberty_Prime_", "created": 1774137280674, "profile_picture": "evWxa80vv4JN", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Combat_Hamster", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASYywAVcs.png", "removal_source": "", "link": "https://twitter.com/travelingflying/status/2035374905298980987?s=20", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Muslims aren't aggressive because Americans did things. They're aggressive because they're Muslims.", "last_comment_created": 1774143096827, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 12, "score_up": 91, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 281, "created": 1774106167000, "id": "2035374905298980987", "video": {"preview": "https://pbs.twimg.com/amplify_video_thumb/2035374831126884352/img/NhBX8UrI44dbahqH.jpg", "mpeg": "https://video.twimg.com/amplify_video/2035374831126884352/pl/7nEm3Z_tTpKxy7zZ.m3u8?v=949", "aspectRatio": [355, 462], "heightRatio": 130, "type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2035374831126884352/vid/avc1/320x416/wiOzJVYNVSHfj3nV.mp4"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/2033948834800529408/CxqNkTup_normal.jpg", "displayName": "Taya", "username": "travelingflying"}, "content": "Christopher Hitchens: \u201dIn 1786, when the United States was barely a country, it was having its sailors taken as slaves by the Barbary states, the states of the Ottoman Empire and North Africa. Tripoli, shores of Tripoli. Ships stopped, its crews carried off into slavery. We", "parentTweet": false, "likes": 20707}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASYyw98Nk", "is_twitter": false, "is_admin": false, "score": 192, "suggested_sort": 0, "post_flair_class": "", "id": 8504378, "raw_content": "There are situations where there's no need to \"be the bigger person\". We don't need to be above celebrating the deaths of our enemies, and shouldn't be above that.\n\nI'm not kidding when I say the Charlie Kirk death celebrations did something to my psyche, by the way. It made me a much more \"fuck you\" person, honestly I would've liked it if Trump was even more hardass with his reactions to Reiner's and Mueller's deaths than he already was, purely just to spite the left. Let them be offended by what he has to say, who gives a damn? Serves them right. I *want* them to be offended. We really should just start collectively letting people be offended.\n\nAnd I'm sure that the Iranian people celebrated the death of their supreme leader when it happened a few weeks ago.", "author": "TheJakeFroggy", "created": 1774122311243, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "anotherthing", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "After seeing the left's absolutely fucking vile celebrations of Charlie Kirk's assassination and what it did to my psyche, I'm not even the least bit offended by what Trump had to say about Rob Mueller's death, and also Rob Reiner's death a few months ago.", "last_comment_created": 1774142875110, "content": "<p>There are situations where there's no need to &quot;be the bigger person&quot;. We don't need to be above celebrating the deaths of our enemies, and shouldn't be above that.</p>\n<p>I'm not kidding when I say the Charlie Kirk death celebrations did something to my psyche, by the way. It made me a much more &quot;fuck you&quot; person, honestly I would've liked it if Trump was even more hardass with his reactions to Reiner's and Mueller's deaths than he already was, purely just to spite the left. Let them be offended by what he has to say, who gives a damn? Serves them right. I <em>want</em> them to be offended. We really should just start collectively letting people be offended.</p>\n<p>And I'm sure that the Iranian people celebrated the death of their supreme leader when it happened a few weeks ago.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 16, "score_up": 192, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASYyw9PZ1", "is_twitter": false, "is_admin": false, "score": 159, "suggested_sort": 0, "post_flair_class": "", "id": 8504497, "raw_content": "", "author": "k-doe3", "created": 1774125358926, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "geckogreen", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASYyw9PZ1.png", "removal_source": "", "link": "https://media.scored.co/post/z2z9xKIamT8W.jpeg", "author_flair_class": "", "is_re