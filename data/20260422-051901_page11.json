8415838208/pl/PTe9wDEwYIARU-FR.m3u8", "aspectRatio": [9, 16], "heightRatio": 177, "type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2046603808415838208/vid/avc1/320x568/776uNeckCX2XHjzM.mp4"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1820801096589221889/ptcYekSS_normal.jpg", "displayName": "Karli Bonne\u2019 \ud83c\uddfa\ud83c\uddf8", "username": "KarluskaP"}, "content": "Dammmmmmmmmn", "parentTweet": false, "likes": 6859}}, "post_flair_text": "\u00a0\u00a0\u00a0\u00a0\u00a0YES\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASZVjgGu6", "is_twitter": false, "is_admin": false, "score": 11, "suggested_sort": 0, "post_flair_class": "", "id": 8573606, "raw_content": "DeSantis and Newsom are a direct contrast, one the governor of the the most successful and fastest-growing state in the country, and the other the governor of the biggest dumpster fire (emphasis on fire) in the country, and the state with the most people moving away (and projected to lose the second-most electoral votes of all-time during the next census).\n\nNewsom would use experience against Vance and Rubio, saying he was the governor of the biggest state in the country and they've never had that kind of responsibility or whatever. But he cannot use that argument against DeSantis.\n\nI know DeSantis did wrong by many people in MAGA by running against Trump in 2024, but offering America the vision of Florida versus California would be a strong sell in swing states.", "author": "duckduck", "created": 1776844393073, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "TonyTreehouse", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Vance and Rubio might be better overall nominees for 2028, but DeSantis would be the best opponent if the Democrat nominee is Newsom.", "last_comment_created": 1776848404377, "content": "<p>DeSantis and Newsom are a direct contrast, one the governor of the the most successful and fastest-growing state in the country, and the other the governor of the biggest dumpster fire (emphasis on fire) in the country, and the state with the most people moving away (and projected to lose the second-most electoral votes of all-time during the next census).</p>\n<p>Newsom would use experience against Vance and Rubio, saying he was the governor of the biggest state in the country and they've never had that kind of responsibility or whatever. But he cannot use that argument against DeSantis.</p>\n<p>I know DeSantis did wrong by many people in MAGA by running against Trump in 2024, but offering America the vision of Florida versus California would be a strong sell in swing states.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 12, "score_up": 11, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZViWmil", "is_twitter": false, "is_admin": false, "score": 135, "suggested_sort": 0, "post_flair_class": "", "id": 8572287, "raw_content": "", "author": "wst4", "created": 1776795095557, "profile_picture": "q5m3F9Z03pfi", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "MAGABOND", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZViWmil.png", "removal_source": "", "link"