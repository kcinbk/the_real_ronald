ive_id": ""}, {"is_locked": false, "tweet_id": "2056938962610971096", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsUZSKzI", "is_twitter": true, "is_admin": false, "score": 15, "suggested_sort": 0, "post_flair_class": "", "id": 8629348, "raw_content": "", "author": "Belleoffreedom", "created": 1779272385588, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "FreeFire", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsUZSKzI.png", "removal_source": "", "link": "https://twitter.com/Eric_Schmitt/status/2056938962610971096?s=20", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "\nEric Schmitt\n@Eric_Schmitt\nWe don\u2019t just have an illegal immigration problem, we have a legal immigration problem too.", "last_comment_created": 1779272987298, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 4, "score_up": 15, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 92, "created": 1779247439000, "id": "2056938962610971096", "video": {"preview": "https://pbs.twimg.com/amplify_video_thumb/2056938612504100864/img/h2UyR9xQgcNGz7hw.jpg", "mpeg": "https://video.twimg.com/amplify_video/2056938612504100864/pl/62NiQHSF0VJlIWjg.m3u8?v=8bc", "aspectRatio": [16, 9], "heightRatio": 56, "type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2056938612504100864/vid/avc1/480x270/NYHoxD1f_HH3RLiS.mp4"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1921711662093963264/HGbbmMam_normal.jpg", "displayName": "Eric Schmitt", "username": "Eric_Schmitt"}, "content": "We don\u2019t just have an illegal immigration problem, we have a legal immigration problem too.\n\nAmericans are tired of coming in second to foreigners.\n\nPresident Trump gets this and it\u2019s time more of my Republican colleagues in Congress understand it too.", "parentTweet": false, "likes": 2993}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASsUZRWAn", "is_twitter": false, "is_admin": false, "score": 38, "suggested_sort": 0, "post_flair_class": "", "id": 8629095, "raw_content": "Who forced the release of the Epstein files??\n\nWho was against the endless foreign aid and one-side alliance with Israel? \n\nWhat about the Iran War??\n\nWhy are people celebrating the loss of Massie when he was largely beaten by the pro-Israel lobby because he was against aid to Israel??\n\nMany of you are celebrating without realizing you\u2019re supporting the pro-Iran War, pro-Israel side, which just showed they can dictate ANY seat in Congress whenever they want. Gallrein is a joke. \n\nIf Charlie Kirk was alive, we likely wouldn\u2019t be at war in Iran, and the pro-Israel support would be minimized. Did anyone actually read Charlie\u2019s letter to Netanyahu?? He was telling Bibi that he was backing off his support of Israel\u2026.and a few months later he was killed.\n\nWhat is more beneficial for Israel\u2014 an alive Charlie whose organization no longer supports Israel, or a memorialized Charlie that was an ardent supporter of Israel (which we saw a push to do after his death)??\n\nNow, considering Kash shut down any investigations into potential foreign leads, who do you think was likely responsible??\n\nStart thinking like grown adults and not being fucking followers and idol-worshippers. ", "author": "xanax123", "created": 1779254613054, "profile_picture": "IaWopu0SqYwp", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Area82", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "WTF is wrong with people here?", "last_comment_created": 1779273709416, "content": "<p>Who forced the release of the Epstein files??</p>\n<p>Who was against the endless foreign aid and one-side alliance with Israel?</p>\n<p>What about the Iran War??</p>\n<p>Why are people celebrating the loss of Massie when he was largely beaten by the pro-Israel lobby because he was against aid to Israel??</p>\n<p>Many of you are celebrating without realizing you\u2019re supporting the pro-Iran War, pro-Israel side, which just showed they can dictate ANY seat in Congress whenever they want. Gallrein is a joke.</p>\n<p>If Charlie Kirk was alive, we likely wouldn\u2019t be at war in Iran, and the pro-Israel support would be minimized. Did anyone actually read Charlie\u2019s letter to Netanyahu?? He was telling Bibi that he was backing off his support of Israel\u2026.and a few months later he was killed.</p>\n<p>What is more beneficial for Israel\u2014 an alive Charlie whose organization no longer supports Israel, or a memorialized Charlie that was an ardent supporter of Israel (which we saw a push to do after his death)??</p>\n<p>Now, considering Kash shut down any investigations into potential foreign leads, who do you think was likely responsible??</p>\n<p>Start thinking like grown adults and not being fucking followers and idol-worshippers.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 60, "score_up": 38, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2056813706089243004", "sticky_comment"