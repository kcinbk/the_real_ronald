val_source": "", "link": "https://media.patriots.win/post/qxSlvl3ZrPv0.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/ALzXOoupjuSc253J.jpeg", "width": 461, "content-type": "jpeg", "height": 768}], "blurhash": "UAD+lIqGOncFz;-;jEsp00.mrErW6P4T-qs,", "full_resolution": [1798, 1079]}, "title": "The Supremely retarded Court just struck down Trump's tariffs. ", "last_comment_created": 1771609809467, "content": "", "score_down": 1, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 14, "score_up": 106, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASFqpq7kd", "is_twitter": false, "is_admin": false, "score": 91, "suggested_sort": 0, "post_flair_class": "hat", "id": 8434317, "raw_content": "Section 301 of the Trade Act of 1974\n\n- Allows tariffs and trade restrictions to address unfair trade practices.\n\n- Used historically to impose tariffs on China.\n\n- Requires an investigation and (at least in theory) consultations with the targeted country.\n\nSection 232 of the Trade Expansion Act of 1962\n\n- Allows tariffs for national security reasons.\n\n- Trump already used this for steel/aluminum tariffs.\n\n- Still valid independently of IEEPA.\n\n Section 122 of the Trade Act of 1974\n\n- Can impose temporary tariffs (up to ~15%) for \u201cbalance-of-payments\u201d reasons.\n\n- Time-limited (e.g., 150 days without extension) and more constrained than IEEPA.\n\nThese authorities are narrower in scope, typically require formal procedures or findings, and (in some cases) are more time-limited than the broad emergency tariffs under IEEPA.", "author": "sleepy_bob_ross", "created": 1771602826979, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "agremlinintheworks", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Trump can still impose Tariffs regardless of the SCOTUS ruling, here's how.", "last_comment_created": 1771614771241, "content": "<p>Section 301 of the Trade Act of 1974</p>\n<ul>\n<li>\n<p>Allows tariffs and trade restrictions to address unfair trade practices.</p>\n</li>\n<li>\n<p>Used historically to impose tariffs on China.</p>\n</li>\n<li>\n<p>Requires an investigation and (at least in theory) consultations with the targeted country.</p>\n</li>\n</ul>\n<p>Section 232 of the Trade Expansion Act of 1962</p>\n<ul>\n<li>\n<p>Allows tariffs for national security reasons.</p>\n</li>\n<li>\n<p>Trump already used this for steel/aluminum tariffs.</p>\n</li>\n<li>\n<p>Still valid independently of IEEPA.</p>\n</li>\n</ul>\n<p>Section 122 of the Trade Act of 1974</p>\n<ul>\n<li>\n<p>Can impose temporary tariffs (up to ~15%) for \u201cbalance-of-payments\u201d reasons.</p>\n</li>\n<li>\n<p>Time-limited (e.g., 150 days without extension) and more constrained than IEEPA.</p>\n</li>\n</ul>\n<p>These authorities are narrower in scope, typically require formal procedures or findings, and (in some cases) are more time-limited than the broad emergency tariffs under IEEPA.</p>\n", "score_down": 2, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 12, "score_up": 93, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "SAVE AMERICA", "archive_id": ""}, {"is_locked": false, "tweet_id": "2024890549141209280", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASFqprDwe"