ated": 1777600984457, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Stars-n-Stripes", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZf5rXxZ.png", "removal_source": "", "link": "https://twitter.com/seanmdav/status/2049909559557296321", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Fantastic news. Comey is a deeply corrupt cop who needs to be held accountable.", "last_comment_created": 1777611325525, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 5, "score_up": 222, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 0, "created": 1777565034000, "id": "2049882445839773710", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1501568753976418304/2w6_XN8r_normal.jpg", "displayName": "Ben Penn", "username": "benjaminpenn"}, "content": "SCOOP: DOJ prosecutors in Virginia are pursuing separate charges against James Comey for allegedly leaking classified info. \nBlanche's DOJ, not satisfied with just '86 47' case, in recent weeks revived nat sec probe that stalled out last year. \n", "parentTweet": false, "likes": 3319}, "images": false, "linkEmbed": false, "replies": 31, "created": 1777571499000, "id": "2049909559557296321", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1461071086020435968/yt0TZ7ut_normal.jpg", "displayName": "Sean Davis", "username": "seanmdav"}, "content": "Fantastic news. Comey is a deeply corrupt cop who needs to be held accountable.", "parentTweet": false, "likes": 4123}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASZf6z7GZ", "is_twitter": false, "is_admin": false, "score": 31, "suggested_sort": 0, "post_flair_class": "", "id": 8593047, "raw_content": "I miss turning on the TV & getting all* the cable* TV channels* (without multiple subscriptions) with basic TV channel numbers that were easy to remember. I miss owning my DVD's & video games. I miss when Mac Donald's had a cool looking building, & when Pizza Hut had a cool roof top. I miss going inside a Blockbuster & being able to buy snacks & look around. I miss the old Xbox (original) days. I miss when iTunes partnered up with Pepsi, to have the yellow pop bottle caps underneath, & being able to redeem the free songs. I miss the $5 foot long at subway. I miss having more cell phone options, & the options to buy a BlackBerry phone (as a kid I always wanted a BlackBerry phone, but my mom never allowed me to get one, even after I was a teen). I miss the old Cartoon Network, & Nickelodeon line ups. I miss the old Starwars. I miss the old Halo days & I miss the old fun that comedy gave us. I miss when movie theaters were having good movies to watch. I miss when AI wasn't a big thing. I miss the old phone styles. I miss when Netflix was only $7.99 a month. I miss the old YouTube from 2005 to 2013. I miss the old wild wild west of the internet days. I miss when being a kid was fun, & being able to be imaginative. I miss the things we lost, & the things that worked. In a way, I miss not being connected to the internet all the time. Thank you for reading this. I hope you can also comments down below on the things you too, miss!", "author": "Beeboy", "created": 1777639430497, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "chickeninoven", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Things I miss growing up!", "last_comment_created": 1777652485921, "content": "<p>I miss turning on the TV &amp; getting all* the cable* TV channels* (without multiple subscriptions) with basic TV channel numbers that were easy to remember. I miss owning my DVD's &amp; video games. I miss when Mac Donald's had a cool looking building, &amp; when Pizza Hut had a cool roof top. I miss going inside a Blockbuster &amp; being able to buy snacks &amp; look around. I miss the old Xbox (original) days. I miss when iTunes partnered up with Pepsi, to have the yellow pop bottle caps underneath, &amp; being able to redeem the free songs. I miss the $5 foot long at subway. I miss having more cell phone options, &amp; the options to buy a BlackBerry phone (as a kid I always wanted a BlackBerry phone, but my mom never allowed me to get one, even after I was a teen). I miss the old Cartoon Network, &amp; Nickelodeon line ups. I miss the old Starwars. I miss the old Halo days &amp; I miss the old fun that comedy gave us. I miss when movie theaters were having good movies to watch. I miss when AI wasn't a big thing. I miss the old phone styles. I miss when Netflix was only $7.99 a month. I miss the old YouTube from 2005 to 2013. I miss the old wild wild west of the internet days. I miss when being a kid was fun, &amp; being able to be imaginative. I miss the things we lost, &amp; the things that worked. In a way, I miss not being connected to the internet all the time. Thank you for reading this. I hope you can also comments down below on the things you too, miss!</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 9, "score_up": 31, "is_edited": true, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZf6zOBK", "is_twitter": false, "is_admin": false, "score": 27, "suggested_sort": 0, "post_flair_class": "hat", "id": 8593126, "raw_content": "", "author": "TakingAction", "created": 1777642135694, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "StrongIsland", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZf6zOBK.png", "removal_source": "", "link": "https://media.scored.co/post/n7olC1upYhYV.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/6mLtTB3qfT0QvRBZ.png", "width": 432, "content-type": "png", "height": 768}], "blurhash": "U1S~x5-;~q-;ITM{jrt800xvD%IVRiM|V@oz", "full_resolution": [1334, 750]}, "title": "\ud83d\udea8\ud83d\udea8\ud83d\udea8Infowars has been taken down \ud83d\udea8\ud83d\udea8\ud83d\udea8", "last_comment_created": 1777647762837, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 14, "score_up": 27, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "SAVE AMERICA", "archive_id": ""}, {"is_locked": false, "tweet_id": "2050251742508699860", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZf70DSh", "is_twitter": true, "is_admin": false, "score": 16, "suggested_sort": 0, "post_flair_class": "", "id": 8593447, "raw_content": "", "author": "rdvs34283", "created": 1777653602381, "profile_picture": "p9HQtdiLq2uP", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "LordCommissarYarrick", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.