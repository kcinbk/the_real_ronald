heightRatio": 125, "type": "video/mp4", "url": "https://video.twimg.com/ext_tw_video/2065587635221884928/pu/vid/avc1/320x400/5VYRAYROKXr3RCIb.mp4"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1779723977167896576/QbNmqZDP_normal.jpg", "displayName": "Damani Felder", "username": "TheDamaniFelder"}, "content": "A message to those still supporting Karmelo Anthony...", "parentTweet": false, "likes": 3187}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASsryXQPc", "is_twitter": false, "is_admin": false, "score": 14, "suggested_sort": 0, "post_flair_class": "", "id": 8677974, "raw_content": "This historic women\u2019s group has been the victim of an insidious plot by trans activists to subvert and destroy it. sneakily getting activists into key roles (President, etc.) in the organization and subtly changing the bylaws to allow biological men to join.\n\nMost members don\u2019t even know it\u2019s happening because the activists have done everything they can to block discussion or debate in forums where the members communicate. They ban members on the official Facebook group just for joining Facebook groups for members trying to oppose it, like Daughters Advocating for Restoration.\n\nhttps://m.facebook.com/groups/1659132851538607/?ref=share\n\nThere is an attempt to fight back against the activists at the Continental Congress this month (June 24 to 28), but with stifled communication, it\u2019s an uphill battle. Many chapters are folding as thousands of members have already resigned in protest and thousands of members and hundreds of chapters will leave if this effort fails.\n\nThis is a 135 year old charitable group that consists primarily of older white conservative women, which is probably why Leftists are targeting it, trying to corrupt and destroy it from within.\n\nFun fact, Trump was sworn in on the golden eagle lectern owned by the organization.\n\nhttps://blog.dar.org/2021/01/19/dar-eagle-lectern-loaned-inaugural-committee", "author": "VictoriaSumma", "created": 1781356675251, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Dwoj", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Trans Activists Destroying Daughters of the American Revolution", "last_comment_created": 1781357320041, "content": "<p>This historic women\u2019s group has been the victim of an insidious plot by trans activists to subvert and destroy it. sneakily getting activists into key roles (President, etc.) in the organization and subtly changing the bylaws to allow biological men to join.</p>\n<p>Most members don\u2019t even know it\u2019s happening because the activists have done everything they can to block discussion or debate in forums where the members communicate. They ban members on the official Facebook group just for joining Facebook groups for members trying to oppose it, like Daughters Advocating for Restoration.</p>\n<p><a rel=\"nofollow\" href=\"https://m.facebook.com/groups/1659132851538607/?ref=share\" target=\"_blank\">https://m.facebook.com/groups/1659132851538607/?ref=share</a></p>\n<p>There is an attempt to fight back against the activists at the Continental Congress this month (June 24 to 28), but with stifled communication, it\u2019s an uphill battle. Many chapters are folding as thousands of members have already resigned in protest and thousands of members and hundreds of chapters will leave if this effort fails.</p>\n<p>This is a 135 year old charitable group that consists primarily of older white conservative women, which is probably why Leftists are targeting it, trying to corrupt and destroy it from within.</p>\n<p>Fun fact, Trump was sworn in on the golden eagle lectern owned by the organization.</p>\n<p><a rel=\"nofollow\" href=\"https://blog.dar.org/2021/01/19/dar-eagle-lectern-loaned-inaugural-committee\" target=\"_blank\">https://blog.dar.org/2021/01/19/dar-eagle-lectern-loaned-inaugural-committee</a></p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 1, "score_up": 14, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2065495103511097382", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsryVDca", "is_twitter": true, "is_admin": false, "score": 179, "suggested_sort": 0, "post_flair_class": "jeb", "id": 8677114, "raw_content": "", "author": "BarneyFrank", "created": 1781305399051, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Dualsporter", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsryVDca.png", "removal_source": "", "link": "https://twitter.com/jk_rowling/status/2065495103511097382?s=46&t=GJqBj8x5w05uQWle9LOfPg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "When You Guys See the Plan You\u2019re Going to Love It!", "last_comment_created": 1781330647510, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 15, "score_up": 179, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 1803, "created": 1781287382000, "id": "2065495103511097382", "video": {"preview": "https: