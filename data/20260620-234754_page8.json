eview": "https://media.scored.co/preview/1ASswhTBb8.png", "removal_source": "", "link": "https://media.patriots.win/post/bqohdLWW5TfW.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/gUMHd7shbFHushEA.png", "width": 564, "content-type": "png", "height": 453}], "blurhash": "U9D,4Y~q00IU4n%MofRjxu9FIUxuD%9FIUt7", "full_resolution": [453, 564]}, "title": "CA election zone", "last_comment_created": 1781966436775, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 4, "score_up": 317, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASt1Du2Ur", "is_twitter": false, "is_admin": false, "score": 60, "suggested_sort": 0, "post_flair_class": "", "id": 8690501, "raw_content": "Saw something last year and posted it but it was so high up and so early in the am I wasn't sure. Just now wife and I were outside adding gravel to our driveway when I looked up and saw a gunmetal grey round egg like thing flying at maybe 5k feet just dancing around in the sky. I thought it was a drone at first but it matches no drone I'm familiar with and it would have to be the size of a single car garage for me to see it at that altitude as clearly as I could. A white jetliner was heading in its direction and maybe about 1/2 -1 mile out and at 10k feet or so and when it was a bout 1/4 mile out the grey ship just went strait up. watched it for about a 45 seconds until it was completely gone guessing it hit the stratosphere or completely left the atmosphere. tried to get a picture of it on my phone but it didn't show in the pictures. My wife says she seen it a few times over the last year while working in the yard. Fucking crazy times we are living in man.    ", "author": "2021Is1776", "created": 1781991522047, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Litecola2", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "well now im certain there are UFOs, wife and I both just saw the damn thing.", "last_comment_created": 1782010831464, "content": "<p>Saw something last year and posted it but it was so high up and so early in the am I wasn't sure. Just now wife and I were outside adding gravel to our driveway when I looked up and saw a gunmetal grey round egg like thing flying at maybe 5k feet just dancing around in the sky. I thought it was a drone at first but it matches no drone I'm familiar with and it would have to be the size of a single car garage for me to see it at that altitude as clearly as I could. A white jetliner was heading in its direction and maybe about 1/2 -1 mile out and at 10k feet or so and when it was a bout 1/4 mile out the grey ship just went strait up. watched it for about a 45 seconds until it was completely gone guessing it hit the stratosphere or completely left the atmosphere. tried to get a picture of it on my phone but it didn't show in the pictures. My wife says she seen it a few times over the last year while working in the yard. Fucking crazy times we are living in man.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 30, "score_up": 60, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASs