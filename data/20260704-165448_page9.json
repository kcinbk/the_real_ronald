eted": false, "is_image": true, "comments": 4, "score_up": 73, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ATBlwHjGe", "is_twitter": false, "is_admin": false, "score": 17, "suggested_sort": 0, "post_flair_class": "", "id": 8713404, "raw_content": "Per capita millionaires (amongst black people only) is the highest in the US. More (per capita) than anywhere else. \n\n\nThis is the question I asked Chatgpt (if you want to try it yourself): \"of all the countries in the world, on average, where is a black person most likely to be a millionaire?\"\n\n\nSo when these \"anti-racists\" start moaning about the US, perhaps we suggest they go and complain about one of the countries that ISN'T the best place for black people in the whole wide world. \n\n\nJust a thought.", "author": "ahamrbond", "created": 1783192598081, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "HanginChad", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Black People Are More Likely To Become Millionaires In The US Than Any Other Country", "last_comment_created": 1783197918337, "content": "<p>Per capita millionaires (amongst black people only) is the highest in the US. More (per capita) than anywhere else.</p>\n<p>This is the question I asked Chatgpt (if you want to try it yourself): &quot;of all the countries in the world, on average, where is a black person most likely to be a millionaire?&quot;</p>\n<p>So when these &quot;anti-racists&quot; start moaning about the US, perhaps we suggest they go and complain about one of the countries that ISN'T the best place for black people in the whole wide world.</p>\n<p>Just a thought.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 4, "score_up": 17, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2073150093755133992", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBlv8Vni", "is_twitter": true, "is_admin": false, "score": 696, "suggested_sort": 0, "post_flair_class": "", "id": 8712136, "raw_content": "", "author": "PiratePatriotParrot", "created": 1783119729809, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Quietam_Unum", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "", "removal_source": "", "link": "https://twitter.com/i/status/2073150093755133992", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Imagine being a grown adult and climbing behind a restaurant counter to steal chicken. Whatever happened to shame?", "last_comment_created": 1783182935842, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 179, "score_up": 696, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 595, "created": 1783112474000, "id": "2073150093755133992", "video": {"preview": "https://pbs.twimg.com/ext_tw_video_thumb/2073150060498460672/pu/img/a6vyRxEdaq41Exkt.jpg", "mpeg": "https://video.twimg.com/ext_tw_video/2073150060498460672/pu/pl/zv4RDe3JyQWZrDfS.m3u8?tag=12&v=8d6", "aspectRati