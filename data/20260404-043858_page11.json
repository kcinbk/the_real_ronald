_state": 2, "link_metadata": {"description": "The chief oversight body responsible for tracking U.S. foreign assistance says United Nations agencies are stonewalling a probe into their ties to Hamas. The agencies have failed to provide investigators with information that could identify their employees as affiliates of the terror group, according to a non-public report transmitted to Congress and obtained by the Washington Free Beacon.", "large_image": "D6d61Vz9K8alFkJN.png", "title": "UN Agencies Are Stonewalling a Probe Into Their Employees' Ties to Hamas, US Investigators Say in Report to Congress"}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2040310724249968702", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZD1GRTN", "is_twitter": true, "is_admin": false, "score": 12, "suggested_sort": 0, "post_flair_class": "", "id": 8535099, "raw_content": "", "author": "PiratePatriotParrot", "created": 1775284071861, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "PiratePatriotParrot", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "", "removal_source": "", "link": "https://twitter.com/MyLordBebo/status/2040310724249968702?s=20", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "The F15 pilots are equipped with a GAU-5A Aircrew Self Defense Weapon (ASDW) 5.56mm rifle.\n\nIt is foldable and is designed to fit into the ejection seat of US Air Force pilots.", "last_comment_created": 1775287674242, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 4, "score_up": 12, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false,