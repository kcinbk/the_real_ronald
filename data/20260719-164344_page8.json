is_deleted": false, "is_image": true, "comments": 0, "score_up": 38, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2078898758322888872", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBvO8hXd", "is_twitter": true, "is_admin": false, "score": 18, "suggested_sort": 0, "post_flair_class": "", "id": 8737001, "raw_content": "", "author": "bleeje", "created": 1784486793697, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Formerlurker92", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBvO8hXd.png", "removal_source": "", "link": "https://twitter.com/KnoxEndemic/status/2078898758322888872", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "\"\u201cService dog\u201d used to mean a large, highly intelligent animal that had been trained and certified for years to guide a blind person through traffic. Now it often means some lady does not want to leave her 8 pound dog at home while buying groceries and needs a justification.\"", "last_comment_created": 1784491402239, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 4, "score_up": 18, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 0, "created": 1784483062000, "id": "2078898758322888872", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1905274727272247296/XyhI1fTv_normal.jpg", "displayName": "KD$ign", "username": "KnoxEndemic"}, "content": "\u201cService dog\u201d used to mean a large, highly intelligent animal that had been trained and certified for years to guide a blind person through traffic.\n\nNow it often means some lady does not want to leave her 8 pound dog at home while buying groceries and needs a justification.", "parentTweet": false, "likes": 5}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ATBvN2VsY", "is_twitter": false, "is_admin": false, "score": 26, "suggested_sort": 0, "post_flair_class": "maha", "id": 8736872, "raw_content": "### Sauerkraut\n\nNo starter culture required, but heavily relies on good technique and setup and is the most prone to process failure (mold). I put that shit on everything. Pizza. Tacos. Salads. More.\n\n### Kefir\n\nStarter required, but is the fastest and simplest to make. Just put milk and kefir grains in a jar and leave on your counter 18-24 hours and you have a delicious creamy tangy drinkable yogurt. You can even add half-and-half or cream to the milk to get even a richer more creamy final product.\n\n### Kombucha\n\nStarter required, but has the most flavor range of the three because it's a drink. I make it from green tea, black tea and even coffee. The primary fermentation product is great by itself, but the real flavor range comes from all the things you can add to it and let partially ferment a second time. My favorite is just to add a little maple syrup and put it into a swing-top glass bottle. It gets very fizzy and delicious and the kids love it.\n\nThis thread is not meant to be an in-depth guide, there is a ton of that information available on the internet. Starters can be found on major online retailers. But if anyone has questions or wants to share their experiences or recipes, I encourage you to do so.\n\nThank you and let's MAHA!", "author": "kek-is-tan", "created": 1784479525837, "profile_picture": "I8XXB1DBtIOB", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "kek-is-tan", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Kraut Kefir Kombucha: A triple-threat of fun, flavor and health that you can make at home.", "last_comment_created": 1784483580810, "content": "<h3>Sauerkraut</h3>\n<p>No starter culture required, but heavily relies on good technique and setup and is the most prone to process failure (mold). I put that shit on everything. Pizza. Tacos. Salads. More.</p>\n<h3>Kefir</h3>\n<p>Starter required, but is the fastest and simplest to make. Just put milk and kefir grains in a jar and leave on your counter 18-24 hours and you have a delicious creamy tangy drinkable yogurt. You can even add half-and-half or cream to the milk to get even a richer more creamy final product.</p>\n<h3>Kombucha</h3>\n<p>Starter required, but has the most flavor range of the three because it's a drink. I make it from green tea, black tea and even coffee. The primary fermentation product is great by itself, but the real flavor range comes from all the things you can add to it and let partially ferment a second time. My favorite is just to add a little maple syrup and put it into a swing-top glass bottle. It gets very fizzy and delicious and the kids love it.</p>\n<p>This thread is not meant to be an in-depth guide, there is a ton of that information available on the internet. Starters can be found on major online retailers. But if anyone has questions or wants to share their experiences or recipes, I encourage you to do so.</p>\n<p>Thank you and let's MAHA!</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 7, "score_up": 26, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "M\u00a0A\u00a0H\u00a0A", "archive_id": ""}, {"is_locked": false, "tweet_id": "2078846067387609238", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBvO8hk8", "is_twitter": true, "is_admin": false, "score": 17, "suggested_sort": 0, "post_flair_class": "", "id": 8737038, "raw_content": "", "author": "R3000", "created": 1784487818091, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "CrvxSacraSitMihiLvx", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBvO8hk8.png", "removal_source": "", "link": "https://twitter.com/joeroganhq/status/2078846067387609238?s=46&t=jjtlmpaOTQdqCbREZwdU3w", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Somali pirates on welfare, needs to end ", "last_comment_created": 1784491326600, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 1, "score_up": 17, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 203, "created": 1784470500000, "id": "2078846067387609238", "video": {"preview": "https://pbs.twimg.com/amplify_video_thumb/2024341956571086848/img/dU5blQ9QbcCmT48r.jpg", "mpeg": "https://video.twimg.com/amplify_video/2024341956571086848/pl/-5Ucspuxlwafx-v8.m3u8?v=e22", "aspectRatio": [300, 151], "heightRatio": 50, "type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2024341956571086848/vid/avc1/536x270/G4nNJwt03Z30WdmE.mp4"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1948879075537272832/dSJpg2hD_normal.jpg", "displayName": "Joe Rogan Podcast News", "use