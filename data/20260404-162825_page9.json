775333191604, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.patriots.win", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZD2PNck.png", "removal_source": "", "link": "https://media.patriots.win/post/rOBfHZnXd2Ue.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/lDF9C3SxvcTLWHxd.jpeg", "width": 768, "content-type": "jpeg", "height": 548}], "blurhash": "UdL#U$aeozV@yZWBs:jsb{WBM_ogR*f6RjbH", "full_resolution": [571, 800]}, "title": "Simply Illustrated", "last_comment_created": 1775333191602, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 0, "score_up": 17, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASZD1HoiS", "is_twitter": false, "is_admin": false, "score": 44, "suggested_sort": 0, "post_flair_class": "", "id": 8535594, "raw_content": "This was the test run for Democrats to steal future elections, not just in WA but other states as well.\r\n\r\nElection night: Rossi led by 261 votes.\r\nAutomatic machine recount: Rossi still led by 42 votes.\r\nDemocrats paid for a manual hand recount.\r\nDuring that process, hundreds of previously uncounted ballots were discovered, mostly in King County.\r\nThe biggest batch was 573 absentee ballots that had been wrongly rejected because workers failed to check paper signature records. \r\nOther counties also found small numbers of missed ballots (e.g., ballots under trays or in machine bins).", "author": "geckogreen", "created": 1775313247313, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Waffle_Stomp", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "In 2004, a Republican won the WA state governor election. That is until Democrats paid to have it recounted with extra ballots they found.", "last_comment_created": 1775328242902, "content": "<p>This was the test run for Democrats to steal future elections, not just in WA but other states as well.</p>\n<p>Election night: Rossi led by 261 votes.\nAutomatic machine recount: Rossi still led by 42 votes.\nDemocrats paid for a manual hand recount.\nDuring that process, hundreds of previously uncounted ballots were discovered, mostly in King County.\nThe biggest batch was 573 absentee ballots that had been wrongly rejected because workers failed to check paper signature records.\nOther counties also found small numbers of missed ballots (e.g., ballots under trays or in machine bins).</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 4, "score_up": 44, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2039900603552596036", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZD1IdOb", "is_twitter": true, "is_admin": false, "score": 30, "suggested_sort": 0, "post_flair_class": "", "id": 8535821, "raw_content": "", "author": "FBIAREFAGGOTS", "created": 1775320619224, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "LordKuroTheGreat", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/p