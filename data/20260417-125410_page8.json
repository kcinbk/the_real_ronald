hard for &quot;blaspheming&quot;\nBut in America, thou shalt not breach.</p>\n<p><a rel=\"nofollow\" href=\"https://chavezatomics.substack.com/p/1789-versus-1789-america-versus-europe?r=4e8jxr\" target=\"_blank\">https://chavezatomics.substack.com/p/1789-versus-1789-america-versus-europe?r=4e8jxr</a></p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 3, "score_up": 22, "is_edited": true, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}], "status": true}