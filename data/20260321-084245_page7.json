": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "OPT positions are entry-level jobs for foreign students that let employers avoid paying payroll taxes (like FICA for Social Security and Medicare). Amazon had 10K in 2024", "last_comment_created": 1774084152281, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 0, "score_up": 21, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 0, "created": 1774023175000, "id": "2035026810862236127", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1424850048525996036/9FCmfzYG_normal.jpg", "displayName": "Project for Immigration Reform", "username": "PFIRorg"}, "content": "Keep in mind that OPT functions as a blanket work authorization for foreign students who complete a degree in the United States. In practice, this has encouraged a proliferation of low-tier institutions that operate less as centers of learning than as conduits for immigration", "parentTweet": false, "likes": 250}, "images": [{"width": 1910, "heightRatio": 97, "url": "https://pbs.twimg.com/media/HD3tMNoboAUy0aU.jpg", "height": 1860}], "linkEmbed": false, "replies": 33, "created": 1774027273000, "id": "2035043998570565923", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1824527179788566528/LORSpSQl_normal.jpg", "displayName": "It's All Coming Together", "username": "All2getherNow"}, "content": "In 2024, there were 10,000 entry-level jobs at Amazon that were given to foreign students through the OPT program.  Amazon doesn't have to pay payroll taxes on these employees.  It is a massive incentive to ignore American grads.", "parentTweet": false, "likes": 1027}}