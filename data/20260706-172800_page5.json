created": 1783208905000, "id": "2073554556470931878", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/2032889871778590724/9g_ykgKQ_normal.jpg", "displayName": "Micah Springut", "username": "mspringut"}, "content": "On the importance of lighting on sculpture.\n\nRead about Daniel Chester French\u2019s desperate campaign to fix the lighting on his Lincoln Memorial statue:", "parentTweet": false, "likes": 18549}, "images": false, "linkEmbed": false, "replies": 11, "created": 1783245601000, "id": "2073708469945848164", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1953042191577972736/YV-bNMV2_normal.jpg", "displayName": "Anish Moonka", "username": "anishmoonka"}, "content": "A sculptor spent eight years on his statue of Abraham Lincoln. Then he walked into the finished memorial, looked up, and barely recognized it. The light had flattened Lincoln's face into a blank, startled mask, and he was sure his masterpiece was ruined.\n\nDaniel Chester French", "parentTweet": false, "likes": 874}}, "post_flair_text": "", "archive_id": ""}], "status": true}