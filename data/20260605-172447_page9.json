hor_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": " CT Republican candidate for state representative is getting criticized on both sides of the political aisle for a recent social media post proclaiming \u201cHappy Straight Month.\u201d ", "last_comment_created": 1780679330390, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 1, "score_up": 40, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"description": "The comments followed Gov. Ned Lamont's announcement designating June as LGBTQ Pride Month", "large_image": "jxaCg0thh99eKEXO.png", "title": "CT Candidate\u2019s \u2018Happy Straight Month\u2019 Social Media Comments Create Flap "}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsnB2Qqv", "is_twitter": false, "is_admin": false, "score": 47, "suggested_sort": 0, "post_flair_class": "", "id": 8661479, "raw_content": "", "author": "kek-is-tan", "created": 1780674149114, "profile_picture": "I8XXB1DBtIOB", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "MatterThatMetals", "is_video": true, "video_link": "https://cdn.videy.co/SGPhav2U1.mp4", "is_new_user": false, "domain": "cdn.videy.co", "is_crosspost": false, "preview": "", "removal_source": "", "link": "https://cdn.videy.co/SGPhav2U1.mp4", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Calm your tits woman. Plus, it's hard to hear you through all this milk.", "last_comment_created": 1780685526287, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 10, "score_up": 47, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASsnB3Fzu", "is_twitter": false, "is_admin": false, "score": 32, "suggested_sort": 0, "post_flair_class": "swamp", "id": 8661772, "raw_content": "The Wall Street Journal reported:\n\n    President Trump said he wants Bill Pulte, his incoming acting director of national intelligence, to begin the process of firing a large number of employees as part of a shake-up of the U.S. intelligence community.\n\n    In an interview with The Wall Street Journal on Friday, Trump said he has privately told Pulte that he believes the Office of the Director of National Intelligence, or ODNI, which oversees 18 federal intelligence agencies and units, is \u201cunnecessary and/or too big.\u201d\n\n    \u201cI\u2019d like to see it smaller. I think there are a lot of people in there that shouldn\u2019t be there,\u201d Trump said, pointing to holdovers from the Biden and Obama administrations. Asked whether he is calling on Pulte to fire people, Trump said he wants him to \u201cstart the process,\u201d adding that his eventual nominee to serve in the role permanently should continue that work.\n\n    Trump stunned many of his own advisers when he said earlier this week that he was appointing Pulte, the director of the Federal Housing Finance Agency, as his intelligence chief. The move was met with skepticism from some Republicans on Capitol Hill, who raised concerns about Pulte\u2019s lack of national-security experience.", "author": "CloudNine", "created": 1780681390718, "profile_picture": "xH7jsorrxzY0", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "grenades_and_ham", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Good News- Acting DNI Bill Pulte is preparing to fire a \u201clarge number\u201d of Deep State Intel Community members.", "last_comment_created": 1780682110310, "content": "<p>The Wall Street Journal reported:</p>\n<pre><code>President Trump said he wants Bill Pulte, his incoming acting director of national intelligence, to begin the process of firing a large number of employees as part of a shake-up of the U.S. intelligence community.\n\nIn an interview with The Wall Street Journal on Friday, Trump said he has privately told Pulte that he believes the Office of the Director of National Intelligence, or ODNI, which oversees 18 federal intelligence agencies and units, is \u201cunnecessary and/or too big.\u201d\n\n\u201cI\u2019d like to see it smaller. I think there are a lot of people in there that shouldn\u2019t be there,\u201d Trump said, pointing to holdovers from the Biden and Obama administrations. Asked whether he is calling on Pulte to fire people, Trump said he wants him to \u201cstart the process,\u201d adding that his eventual nominee to serve in the role permanently should continue that work.\n\nTrump stunned many of his own advisers when he said earlier this week that he was appointing Pulte, the director of the Federal Housing Finance Agency, as his intelligence chief. The move was met with skepticism from some Republicans on Capitol Hill, who raised concerns about Pulte\u2019s lack of national-security experience.\n</code></pre>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 1, "score_up": 32, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "\u00a0\ud83d\udebd\u00a0\u00a0\u00a0DRAIN THE SWAMP\u00a0\u00a0\u00a0\ud83d\udebd\u00a0", "archive_id": ""}, 