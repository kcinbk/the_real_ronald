 design \u2014 where", "large_image": "BmFkD4woqcrYIdwX.png", "title": "#systemsthinking #engineeringmarvels #innovation #historicalengineering #clockwork #automata #bowesmuseum #craftsmanship #aiinfrastructure #legacy | Jonathan Gibbs | 31 comments"}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsZAS9Tl", "is_twitter": false, "is_admin": false, "score": 17, "suggested_sort": 0, "post_flair_class": "swamp", "id": 8634519, "raw_content": "", "author": "SenorTrumper", "created": 1779480728712, "profile_picture": "jau0FhbIn31Y", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Filetsmignon", "is_video": true, "video_link": "https://www.youtube.com/embed/nITn7G3ExDI?start=0", "is_new_user": false, "domain": "www.youtube.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASsZAS9Tl.png", "removal_source": "", "link": "https://www.youtube.com/watch?v=nITn7G3ExDI", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "BREAKING: Tulsi was fired, but we all knew that after the ClA raided her office a few days ago and seized files. ", "last_comment_created": 1779483845491, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 25, "score_up": 17, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "\u00a0\ud83d\udebd\u00a0\u00a0\u00a0DRAIN THE SWAMP\u00a0\u00a0\u00a0\ud83d\udebd\u00a0", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASsZAS9kD", "is_twitter": false, "is_admin": false, "score": 16, "suggested_sort": 0, "post_flair_class": "", "id": 8634555, "raw_content": "", "author": "perma-maga", "c