ull_resolution": []}, "title": "House Speaker Johnson rejects request for Jesse Jackson to lie in honor at Capitol", "last_comment_created": 1771618546855, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 7, "score_up": 97, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"description": "House Speaker Mike Johnson has denied a request for the late Rev. Jesse Jackson Sr. to lie in honor at the United States Capitol, citing past precedent over how the deaths of other high-profile figures were handled, according to sources familiar with the matter.", "large_image": "iFDG8sND8COh2Dpj.png", "title": "House Speaker Johnson rejects request for Jesse Jackson to lie in honor at Capitol | CNN Politics"}, "post_flair_text": "\u00a0SALT MUST FLOW\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASFqpqPGY", "is_twitter": false, "is_admin": false, "score": 138, "suggested_sort": 0, "post_flair_class": "", "id": 8434486, "raw_content": "In September\u202f2025, the U.S. government (via a presidential proclamation) introduced a one\u2011time $100,000 payment requirement attached to most new H\u20111B visa petitions for workers outside the United States \u2014 effective Sept\u202f21,\u202f2025. This new requirement will hit employers throughout 2026 and 2027. Employers filing a new H\u20111B petition for a worker outside the U.S. generally must pay a one-time $100,000 fee per petition.\n\nFY\u202f2026: ~336,000 unique beneficiaries (or ~339,000 by some counts)\n\nFY\u202f2025: ~442,000 unique beneficiaries\nSo there was a drop from roughly 442\u202fK down to ~336\u202fK between those two years\n\n\nhttps://www.whitehouse.gov/presidential-actions/2025/09/restriction-on-entry-of-certain-nonimmigrant-workers/\n", "author": "HorrorGameDev", "created": 1771606692800, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Formerlurker92", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Trump listened: The H1B program has shrunk 25% for 2026 and employers must pay $100k for new foreign talent. TX has also suspended all new public sector H1B requests. A good start, but keep going. ", "last_comment_created": 1771616809876, "content": "<p>In September\u202f2025, the U.S. government (via a presidential proclamation) introduced a one\u2011time $100,000 payment requirement attached to most new H\u20111B visa petitions for workers outside the United States \u2014 effective Sept\u202f21,\u202f2025. This new requirement will hit employers throughout 2026 and 2027. Employers filing a new H\u20111B petition for a worker outside the U.S. generally must pay a one-time $100,000 fee per petition.</p>\n<p>FY\u202f2026: ~336,000 unique beneficiaries (or ~339,000 by some counts)</p>\n<p>FY\u202f2025: ~442,000 unique beneficiaries\nSo there was a drop from roughly 442\u202fK down to ~336\u202fK between those two years</p>\n<p><a rel=\"nofollow\" href=\"https://www.whitehouse.gov/presidential-actions/2025/09/restriction-on-entry-of-certain-nonimmigrant-workers/\" target=\"_blank\">https://www.whitehouse.gov/presidential-actions/2025/09/restriction-on-entry-of-certain-nonimmigrant-workers/</a></p>\n", "score_down": 1, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 17, "score_up": 139, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, 