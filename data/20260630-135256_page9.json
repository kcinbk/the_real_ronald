, "score_up": 40, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ATBhJ1OeT", "is_twitter": false, "is_admin": false, "score": 24, "suggested_sort": 0, "post_flair_class": "", "id": 8706315, "raw_content": "Sisamnes was, according to Herodotus's Histories, book 5, chapter 25, a corrupt royal judge active in the Persian empire during the reign of Cambyses II of Persia. When Cambyses learned that Sisamnes had accepted a bribe to influence a verdict, he had him promptly arrested and sentenced him to be flayed alive. He had the skin of the flayed Sisamnes cut into leather strips. Cambyses then appointed Otanes, the son of the condemned Sisamnes, as his father's judicial successor. In order to remind Otanes what happens to corrupt judges and not forget the importance of judicial integrity, Cambyses ordered that the new judge's chair be draped in the leather strips made from the skin of the flayed Sisamnes.[1] Otanes later became a satrap in Ionia.[2] Cambyses warned Otanes to continually keep in mind the source of the leather of the chair upon which he would be seated to deliberate and deliver his judgment.", "author": "1DontTreadOnMe1", "created": 1782835753751, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "After today's SCOTUS ruling on birthright citizenship, it's more important than ever that those judges know the name Sisamnes, and what happens to corrupt judges.", "last_comment_created": 1782835753750, "content": "<p>Sisamnes was, according to Herodotus's Histories, book 5, chapter 25, a corrupt royal judge active in the Persian empire during the reign of Cambyses II of Persia. When Cambyses learned that Sisamnes had accepted a bribe to influence a verdict, he had him promptly arrested and sentenced him to be flayed alive. He had the skin of the flayed Sisamnes cut into leather strips. Cambyses then appointed Otanes, the son of the condemned Sisamnes, as his father's judicial successor. In order to remind Otanes what happens to corrupt judges and not forget the importance of judicial integrity, Cambyses ordered that the new judge's chair be draped in the leather strips made from the skin of the flayed Sisamnes.[1] Otanes later became a satrap in Ionia.[2] Cambyses warned Otanes to continually keep in mind the source of the leather of the chair upon which he would be seated to deliberate and deliver his judgment.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 0, "score_up": 24, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2071970664324448684", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBhJ1fhZ", "is_twitter": true, "is_admin": false, "score": 21, "suggested_sort": 0, "post_flair_class": "", "id": 8706419, "raw_content": "", "author": "PiratePatriotParrot", "created": 1782838354275, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "highenergywinning", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBhJ1fhZ.png", "removal_source": "", "link": "https://twitter.com/i/status/2071970664324448684", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "ful