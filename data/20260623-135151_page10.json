s": "", "id": 8694091, "raw_content": "", "author": "China4Biden", "created": 1782198103376, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Tacoboutit", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.patriots.win", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASt1IQFvt.png", "removal_source": "", "link": "https://media.patriots.win/post/3gQ5LA8UY4Oi.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/D1aBUmHeys8txVta.jpeg", "width": 692, "content-type": "jpeg", "height": 768}], "blurhash": "U25#ka~qM{M{-=t8xuWB9FRj%MRj%Mt7%2Rj", "full_resolution": [1483, 1337]}, "title": "FEMINIST HYPOCRISY!!!!!", "last_comment_created": 1782235099917, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 10, "score_up": 107, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASt1IRtlI", "is_twitter": false, "is_admin": false, "score": 18, "suggested_sort": 0, "post_flair_class": "", "id": 8694628, "raw_content": "", "author": "Michalusmichalus", "created": 1782232965969, "profile_picture": "NNi2gF2DmJPh", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "HikingInTrumpCountry", "is_video": false, "video_link": "", "is_new_user": false, "domain": "thehill.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASt1IRtlI.png", "removal_source": "", "link": "https://thehill.com/opinion/education/5931663-decline-reading-math-scores/", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "It's Common Core. Dumbed down intentionally. ", "last_comment_created": 1782236684472, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 11, "score_up": 18, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"description": "American classrooms are seeing a decline in reading and math scores, which is a civilizational issue as it is linked to a decline in IQ scores, and is exacerbated by the use of AI which weakens jud\u2026", "large_image": "0pSWHAOWEzm7ohff.png", "title": "How did basic literacy stop being a prerequisite for college?"}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASt1IRcye", "is_twitter": false, "is_admin": false, "score": 21, "suggested_sort": 0, "post_flair_class": "", "id": 8694560, "raw_content": "The worlds largest hyperscale data center can consume 35,000,000 gallons per week.\n\n&nbsp;\n\nGOOGLE SAYS there's only 14,000,000 (LOL) illegals living in the US. GOOGLE SAYS 574 gallons of water per week are consumed by an individual. (Average). 574 x 14,000,000= 8,036,000,000 (that's billion) gallons per week.\n\n&nbsp;\n\n8,036,000,000 / 35,000,000 =  229.6. So over 229 data centers could be cooled with no hit on infrastructure by deporting 14,000,000 illegals. \n\n&nbsp;\n\nDecided to do the math because I'm tired of hearing about water and data centers. Illegals use more water than data centers. Remember that the next time a lefty is bitching about us wanting illegals deported and/ or bitching about data centers on the internet. Which exists in a data center somewhere. ", "author": "Siteless_Vagrant", "created": 1782229905676, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Siteless_Vagrant", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Just some fun math. ", "last_comment_created": 1782236173605, "content": "<p>The worlds largest hyperscale data center can consume 35,000,000 gallons per week.</p>\n<p>\u00a0</p>\n<p>GOOGLE SAYS there's only 14,000,000 (LOL) illegals living in the US. GOOGLE SAYS 574 gallons of water per week are consumed by an individual. (Average). 574 x 14,000,000= 8,036,000,000 (that's billion) gallons per week.</p>\n<p>\u00a0</p>\n<p>8,036,000,000 / 35,000,000 =  229.6. So over 229 data centers could be cooled with no hit on infrastructure by deporting 14,000,000 illegals.</p>\n<p>\u00a0</p>\n<p>Decided to do the math because I'm tired of hearing about water and data centers. Illegals use more water than data centers. Remember that the next time a lefty is bitching about us wanting illegals deported and/ or bitching about data centers on the internet. Which exists in a data center somewhere.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 6, "score_up": 21, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2069358375670890945", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASt1IQnhN", "is_twitter": true, "is_admin": false, "score": 41, "suggested_sort": 0, "post_flair_class": "", "id": 8694245, "raw_content": "", "author": "PatriotSam", "created": 1782216682798, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Somebody157", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASt1IQnhN.png", "removal_