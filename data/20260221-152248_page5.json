h": "", "full_resolution": []}, "title": "Matthew McConaughey has been granted 8 trademarks of his image and voice in order to provide legal grounds for federal lawsuits against AI-generated content without authorization/compensation.\r\n\r\n", "last_comment_created": 1771698631837, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 9, "score_up": 57, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"description": "Actor banks on federal trademarks of voice, images to deter AI clones and unauthorized use", "large_image": "qsq65t4tVy25PEDC.png", "title": "Hollywood star Matthew Mcconaughey trademarks himself to stop AI deepfakes"}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASFqs6NE7", "is_twitter": false, "is_admin": false, "score": 165, "suggested_sort": 0, "post_flair_class": "", "id": 8436197, "raw_content": "", "author": "ArthurJ", "created": 1771672660374, "profile_picture": "2n7j40CvvfEB", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASFqs6NE7.png", "removal_source": "", "link": "https://media.scored.co/post/72bcanugWN3F.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/ne9p9byzKmEKGO8C.png", "width": 485, "content-type": "png", "height": 612}], "blurhash": "ULEyV*_4IpIT00Int6t7ISM_jEtR?I%MShRj", "full_resolution": [612, 485]}, "title": "Consequences .....", "last_comment_created": 1771672660374, "content": "", "score_down": 1, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 0, "score_up": 166, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASFqtEUEK", "is_twitter": false, "is_admin": false, "score": 43, "suggested_sort": 0, "post_flair_class": "", "id": 8437020, "raw_content": "1) You pay a poll tax equivalent to $75-250. That money goes towards setting up the voting infrastructure. People who don't care about voting that year won't be obligated to fund anything related to the election. This also dissuades people from voting who shouldn't be.\n2) You must pass a test on the Constitution and basic civics. Passing is a 70/100. All of the potential topics are available to the public. \n3) You must sign an oath in English. If you are caught cheating, you will be found guilty of a felony with a mandatory sentence of 6-12 months. \n4) The tests are graded by a 1980s pre electronic scantron in a completely different area of the country. \n5) The test must be administered in person with at least 2 Proctors in the room being recorded the entire time. No bathroom breaks. You have 90 minutes. \n6) If you fail the test, you have to wait at least another 6-12 months to take it again. ", "author": "HorrorGameDev", "created": 1771700079283, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "HorrorGameDev", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Universal voting is a fraud. You should have to pass a civics test given in English to qualify to vote and run for office ", "last_comment_created": 1771700359969, "content": "<ol>\n<li>You pay a poll tax equivalent to $75-250. That money goes towards setting up the voting infrastructure. People who don't care about voting that year won't be obligated to fund anything related to the election. This also dissuades people from voting who shouldn't be.</li>\n<li>You must pass a test on the Constitution and basic civics. Passing is a 70/100. All of the potential topics are available to the public.</li>\n<li>You must sign an oath in English. If you are caught cheating, you will be found guilty of a felony with a mandatory sentence of 6-12 months.</li>\n<li>The tests are graded by a 1980s pre electronic scantron in a completely different area of the country.</li>\n<li>The test must be administered in person with at least 2 Proctors in the room being recorded the entire time. No bathroom breaks. You have 90 minutes.</li>\n<li>If you fail the test, you have to wait at least another 6-12 months to take it again.</li>\n</ol>\n", "score_down": 1, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 3, "score_up": 44, "is_edited": true, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2024910705263026407", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASFqs7C6g", "is_twitter": true, "is_admin": false, "score": 99, "suggested_sort": 0, "post_flair_class": "", "id": 8436456, "raw_content": "", "author": "grannylovestrump", "created": 1771682426347, "profile_picture": "J2VOs7hvr5If", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Scipio_Americanus", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASFqs7C6g.png", "removal_source": "", "link": "https://twitter.com/trad_west_/status/2024910705263026407", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash