link_metadata": {"twitter": {"quotedTweet": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 0, "created": 1777405876000, "id": "2049214888720105552", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1928294155077230592/Kd0tDhAS_normal.jpg", "displayName": "AAGHarmeetDhillon", "username": "AAGDhillon"}, "content": "We just sued Cloudera for discriminating against U.S. workers in favor of foreign visa holders for high-paying tech jobs. This is a violation of the Immigration & Nationality Act, & @CivilRights will not hesitate to sue employers for discriminating against U.S. workers! You are", "parentTweet": false, "likes": 13562}, "images": [{"width": 1320, "heightRatio": 176, "url": "https://pbs.twimg.com/media/HHBRgDzbgAAjFFE.jpg", "height": 2335}], "linkEmbed": false, "replies": 187, "created": 1777408870000, "id": "2049227446743093370", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1555334534308147200/nV4UpiWl_normal.jpg", "displayName": "Hany Girgis", "username": "SanDiegoKnight"}, "content": "\ud83d\udea8 BREAKING: The DOJ just sued Cloudera for rigging high-paying tech jobs against American workers.\n\nThey created a fake internal email that bounced every U.S. applicant\u2019s resume \u2026then claimed \u201cno qualified Americans applied\u201d to fast-track foreign visa holders for green cards.", "parentTweet": false, "likes": 11922}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASZaX8W6j", "is_twitter": false, "is_admin": false, "score": 20, "suggested_sort": 0, "post_flair_class": "", "id": 8589121, "raw_content": "According to an independent study, \u201cconversion therapy\u201d does not increase of suicide amongst the LGBT who seek it, it actually lowers the risk but the proponent of conversion therapy who conducted the study admitted that \u201cconversion therapy\u201d does not rid an individual of same-sex attractions entirely, but rather reduces the power they have over the person and awakens and strengthens with them, the natural \u201copposite-sex\u201d attractions that were instilled in them by God.\n\nWhile people should be well informed of both the potential benefits and risks of certain therapies and treatments they may consider pursuing, they should not be denied access to those therapies and treatments no matter the controversy surrounding them.  Conversion therapy may not work for all people struggling with unwanted same-sex attractions, but it does work for some but the LGBT community, in order to maintain the credibility of the narrative that sexual orientation and identity cannot be changed but is fixed, would keep in bondage to same-sex attractions those who long to be rid of the attractions they don\u2019t want.\n\nhttps://www.dailysignal.com/2024/01/31/new-research-conversion-therapy-turns-lgbtq-narrative-head/\n", "author": "ContendersEdge", "created": 1777475788350, "profile_picture": "OTUZVRkFHNZn", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Mintap", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "According to an independent study, \u201cconversion therapy\u201d does not increase of suicide amongst the LGBT who seek it...\n", "last_comment_created": 1777481433020, "content": "<p>According to an independent study, \u201cconversion therapy\u201d does not increase of suicide amongst the LGBT who seek it, it actually lowers the risk but the proponent of conversion therapy who conducted the study admitted that \u201cconversion therapy\u201d does not rid an individual of same-sex attractions entirely, but rather reduces the power they have over the person and awakens and strengthens with them, the natural \u201copposite-sex\u201d attractions that were instilled in them by God.</p>\n<p>While people should be well informed of both the potential benefits and risks of certain therapies and treatments they may consider pursuing, they should not be denied access to those therapies and treatments no matter the controversy surrounding them.  Conversion therapy may not work for all people struggling with unwanted same-sex attractions, but it does work for some but the LGBT community, in order to maintain the credibility of the narrative that sexual orientation and identity cannot be changed but is fixed, would keep in bondage to same-sex attractions those who long to be rid of the attractions they don\u2019t want.</p>\n<p><a rel=\"nofollow\" href=\"https://www.dailysignal.com/2024/01/31/new-research-conversion-therapy-turns-lgbtq-narrative-head/\" target=\"_blank\">https://www.dailysignal.com/2024/01/31/new-research-conversion-therapy-turns-lgbtq-narrative-head/</a></p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 6, "score_up": 20, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZaX8nUS", "is_twitter": false, "is_admin": false, "score": 16, "suggested_sort": 0, "post_flair_class": "", "id": 8589274, "raw_content": "", "author": "Trick", "created": 1777480165465, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "", "is_video": false, "video_link": "", "is_new_user": false, "domain": "babylonbee.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZaX8nUS.png", "removal_source": "", "link": "https://babylonbee.com/news/in-blow-to-democ