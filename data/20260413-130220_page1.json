n support Trump and America First and this will not change.  We are not going to update the rules to allow open Trump hating and we will be enforcing any overt anti Trump rhetoric with due diligence. There is no quarter for those who would have rather had an auto pen owned by Soros in office.</p>\n<p>We are America First, we will Make America Great Again even if I have to do it all myself while holding pepe's hand.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 842, "score_up": 1203, "is_edited": true, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZMOdPEd", "is_twitter": false, "is_admin": false, "score": 107, "suggested_sort": 0, "post_flair_class": "", "id": 8555987, "raw_content": "", "author": "Cyber1776", "created": 1776094004922, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "barwhack", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZMOdPEd.png", "removal_source": "", "link": "https://media.scored.co/post/cpOlTjDaHUIK.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/4y81U44EbQNKHfYN.jpeg", "width": 768, "content-type": "jpeg", "height": 742}], "blurhash": "U7ELvn0K4n~W00?Hkr9F0Q%2-S-;9cWUaJD*", "full_resolution": [1087, 1125]}, "title": "Too incompetent ", "last_comment_created": 1776099664290, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 7, "score_up": 107, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_meta