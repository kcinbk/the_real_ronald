edTweet": false, "images": false, "linkEmbed": false, "replies": 0, "created": 1775352583000, "id": "2040602752095596674", "video": {"preview": "https://pbs.twimg.com/amplify_video_thumb/2040602669593550849/img/_lX_vV5AOo0kVNFy.jpg", "mpeg": "https://video.twimg.com/amplify_video/2040602669593550849/pl/Mqy7AQPd7SP8D31V.m3u8?tag=14&v=076", "aspectRatio": [16, 9], "heightRatio": 56, "type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2040602669593550849/vid/avc1/480x270/Ly86f4wcyStZvPE3.mp4?tag=14"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/2007442343822041090/aAqm85s__normal.jpg", "displayName": "CBS Evening News with Tony Dokoupil", "username": "CBSEveningNews"}, "content": "For decades, the U.S. has imported highly-skilled tech workers from around the world on H-1B visas. But the Trump administration changed the way they are granted. CBS News\u2019 Shanelle Kaul reports on how that is impacting the pipeline of global talent coming to America.", "parentTweet": false, "likes": 565}, "images": false, "linkEmbed": false, "replies": 188, "created": 1775397601000, "id": "2040791572665512264", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1482179968083836928/7prxRZ4M_normal.jpg", "displayName": "Wall Street Mav", "username": "WallStreetMav"}, "content": "80% of H-1B visas go to entry level or junior level positions.\n\nThey are not even remotely \u201chigh skilled\u201d. They are merely cheaper.\n\nH-1B is a scam and needs to be scrapped entirely.", "parentTweet": false, "likes": 6081}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2040861434125418962", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZD4hXuN", "is_twitter": true, "is_admin": false, "score": 367, "suggested_sort": 0, "post_flair_class": "", "id": 8538723, "raw_content": "", "author": "_Liberty_Prime_", "created": 1775430919106, "profile_picture": "evWxa80vv4JN", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Buck_O_Five", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZD4hXuN.png", "removal_source": "", "link": "https://twitter.com/CompanyHooch/status/2040861434125418962?s=20", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "The Metric System Won't Save You.", "last_comment_created": 1775463054991, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 30, "score_up": 367, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 0, "created": 1775392281000, "id": "2040769258758766992", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1731655701301178368/iTXTRBfW_normal.jpg", "displayName": "Hunter\ud83d\udcc8\ud83c\udf08\ud83d\udcca", "username": "StatisticUrban"}, "content": "It's insane to me that most Americans can't even comprehend metric units and Celsius without converting.\n\nI understand it's not the system used, but it IS the international system, used in all scientific fields and ~every other country. Useful to at least instill the basics.", "parentTweet": false, "likes": 420}, "images": false, "linkEmbed": false, "replies": 6, "created": 1775414257000, "id": "2040861434125418962", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/2038774221308854272/BXrDlKpn_normal.jpg", "displayName": "Hooch", "username": "CompanyHooch"}, "content": "The basics are that when you need freedom it will arrive in miles per hour and be applied in foot-pounds.", "parentTweet": false, "likes": 581}}, "post_flair_text": "", "archive_id": ""}], "status": true}