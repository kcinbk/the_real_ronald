t": false, "likes": 536}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2073493518178476075", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBlxP2C0", "is_twitter": true, "is_admin": false, "score": 136, "suggested_sort": 0, "post_flair_class": "", "id": 8714098, "raw_content": "", "author": "DebunkTheLeft", "created": 1783223937213, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Tacoboutit", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBlxP2C0.png", "removal_source": "", "link": "https://twitter.com/dissidentwest/status/2073493518178476075", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "According to Mamdani this is how New York City was built.", "last_comment_created": 1783254971634, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 2, "score_up": 136, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": [{"width": 2304, "heightRatio": 77, "url": "https://pbs.twimg.com/media/HMZ9RqMaYAAwh0H.jpg", "height": 1792}], "linkEmbed": false, "replies": 25, "created": 1783194353000, "id": "2073493518178476075", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1808204478216052737/eUyt4kne_normal.jpg", "displayName": "Dissident West", "username": "dissidentwest"}, "content": "According to Mamdani this is how New York City was built.", "parentTweet": false, "likes": 6052}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ATBlxQ8O4", "is_twitter": false, "is_admin": false, "score": 17, "suggested_sort": 0, "post_flair_class": "", "id": 8714494, "raw_content": "When Poland regained its independence after WWI, the young state faced massive economic chaos, hyperinflation, and deep-seated systemic corruption inherited from the partitioning empires. To combat this, the Polish parliament passed a draconian emergency anti-corruption law in 1920 (updated in 1921): The Act on Punishing Crimes Committed by Officials Out of Greed.\n\nUnder this law, if a state official or politician over the age of 21 accepted bribes, embezzled funds, or intentionally caused massive financial damage to the state treasury for personal gain, the mandatory penalty was death by firing squad or life imprisonment.\n\nThere was a fascinating \"safe harbor\" clause, though: an official could entirely escape the death penalty if they voluntarily returned the stolen assets or fully repaired the financial damage before the authorities officially uncovered the crime.\n\nThese extreme measures were treated as a temporary crisis-management tool. When Poland unified its legal system with the modern Penal Code of 1932, capital punishment for economic crimes was abolished, restricting it strictly to murder and treason.", "author": "NSFW_PORN_ONLY", "created": 1783264550286, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Live_free_or_die_55", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "TIL that in interwar Poland (1920\u20131932), corrupt politicians and state officials could be sentenced to death by a firing squad for taking bribes or embezzling public funds.", "last_comment_created": 1783265029444, "content": "<p>When Poland regained its independence after WWI, the young state faced massive economic chaos, hyperinflation, and deep-seated systemic corruption inherited from the partitioning empires. To combat this, the Polish parliament passed a draconian emergency anti-corruption law in 1920 (updated in 1921): The Act on Punishing Crimes Committed by Officials Out of Greed.</p>\n<p>Under this law, if a state official or politician over the age of 21 accepted bribes, embezzled funds, or intentionally caused massive financial damage to the state treasury for personal gain, the mandatory penalty was death by firing squad or life imprisonment.</p>\n<p>There was a fascinating &quot;safe harbor&quot; clause, though: an official could entirely escape the death penalty if they voluntarily returned the stolen assets or fully repaired the financial damage before the authorities officially uncovered the crime.</p>\n<p>These extreme measures were treated as a temporary crisis-management tool. When Poland unified its legal system with the modern Penal Code of 1932, capital punishment for economic crimes was abolished, restricting it strictly to murder and treason.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 1, "score_up": 17, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ATBlwHSgW", "is_twitter": false, "is_admin": false, "score": 703, "suggested_sort": 0, "post_flair_class": "", "id": 8713374, "raw_content": "", "author": "Cali_kid", "created": 1783191759355, "profile_picture": "NFAyPd5cA0L6", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Chickensaurus", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ATBlwHSgW.png", "re