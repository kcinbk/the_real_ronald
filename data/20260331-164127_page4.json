, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 15, "score_up": 66, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"description": "Scientists have developed a breakthrough \u201csuperfood\u201d for honeybees by engineering yeast to produce the essential nutrients normally found in pollen. In controlled trials, colonies fed this specially designed diet produced up to 15 times more young, showing a dramatic boost in reproduction and overall health. As climate change and modern agriculture reduce the availability of natural pollen, this innovation could offer a practical way to support struggling bee populations.", "large_image": "WcMWyPQTxIY23oF6.png", "title": "Scientists uncovered the nutrients bees were missing \u2014 Colonies surged 15-fold"}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2038768090037518463", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZ8LjabA", "is_twitter": true, "is_admin": false, "score": 69, "suggested_sort": 0, "post_flair_class": "", "id": 8526068, "raw_content": "", "author": "Belleoffreedom", "created": 1774976007872, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Shmioighan", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZ8LjabA.png", "removal_source": "", "link": "https://twitter.com/julie_kelly2/status/2038768090037518463?s=20", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "What kind of irresponsible fools give out CDLs like candy to the Blatantly Unqualified?", "last_comment_created": 1774981202946, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": f