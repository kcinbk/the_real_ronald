tent": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 3, "score_up": 40, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2034013799334736019", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASGIyyGkq", "is_twitter": true, "is_admin": false, "score": 30, "suggested_sort": 0, "post_flair_class": "chopper", "id": 8495458, "raw_content": "", "author": "TrancePhreak", "created": 1773788827910, "profile_picture": "TnB3aAUmUKpm", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Goozmania", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASGIyyGkq.png", "removal_source": "", "link": "https://twitter.com/jacktronprime/status/2034013799334736019?s=20", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Remember back last year when that whole SignalGate thing happened?", "last_comment_created": 1773794080552, "content": "", "score_down": 4, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 4, "score_up": 34, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": [{"width": 1236, "heightRatio": 30, "url": "https://pbs.twimg.com/media/HDpExRQbwAAcXMC.jpg", "height": 372}], "linkEmbed": false, "replies": 48, "created": 1773781654000, "id": "2034013799334736019", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/2012170981041721345/oVTqEzcV_normal.jpg", "displayName": "Jacktron", "username": "jacktronprime"}, "content": "Remember back last year when that whole SignalGate thing happened?\n\nAn anti-Trump journalist from the Atlantic somehow got inside that Signal Chat talking about the attacks on the Houthis and the democrats demanded Pete Hegseth resign over it.\n\nGuess who was in that chat?\n\nJoe", "parentTweet": false, "likes": 1329}}, "post_flair_text": "\ud83d\ude81 FREE CHOPPER RIDES \ud83d\ude81", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASGIyyXnk", "is_twitter": false, "is_admin": false, "score": 25, "suggested_sort": 0, "post_flair_class": "fight", "id": 8495550, "raw_content": "", "author": "Northpoint12", "created": 1773792404324, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "stylecouncilor", "is_video": false, "video_link": "", "is_new_user": false, "domain": "rumble.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASGIyyXnk.png", "removal_source": "", "link": "https://rumble.com/v7792pa-age-verification-i-will-not-be-taking-part-of-it-thank-you..html", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Age Verification - I do not comply", "last_comment_created": 1773798246721, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 6, "score_up": 25, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"rumble_embed": "https://rumble.com/embed/v752ep2/"}, "post_flair_text": "FIGHT,\u00a0\u00a0FIGHT,\u00a0\u00a0FIGHT!", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASGIxqhBH", "is_twitter": false, "is_admin": false, "score": 90, "suggested_sort": 0, "post_flair_class": "", "id": 8494727, "raw_content": "This site currently requires that we be here to support MAGA and Trump. \n\nSupporting MAGA is a given. Requiring Trump support made complete sense when this website was vital in national elections and Trump was the candidate. That's done now, he got his two (three) terms. \n\nWhy require it now? \n\nIt's becoming increasingly clear that this administration and Trump personally are overly influenced by special interests that too often diverge from genuine America First principles - which is what most of us thought MAGA was about.\n\nTo be clear, I still support Trump, but pretty lukewarmly. He's, obviously, much better than the alternative and I do not regret my votes and support. I will continue to defend him.\n\nBut I'm also disappointed. Epstein files, slowrolled and backtracked deportations, lack of action on election fraud, lack of action against the deep state and other internal enemies, etc. The more-war-for-Israel thing isn't something I'm thrilled about either. I'm not as against it as many here, I don't particularly mind as long as we don't end up in something protracted with ground forces committed, I'd just rather see us not do the bidding of foreign powers with so many of our own problems remaining unsolved. Perhaps part of it is that Trump's scope for domestic action has been constrained by the treasonous GOP. But still. \n\nIt's clear that we need a lot better in the future. He's probably the best we could have hoped for 2017-2029. He's the first stepping stone to securing our sovereignty but, obviously, not the end goal. \n\nAt some point we have to let go of Trump. And this site at some point needs to transition. 2028 is coming. We need a more America First candidate. And we need to be able to talk critically.\n\nIf anyone looks through major threads, Israel First shills are downvoted to oblivion and people critical of Trump right now get upvoted. So it's clear that many of us are already 'violating' the 'be here to support Trump' rule.\n\nI'm not suggesting that we turn *against* Trump. I'm saying that qualified support and open criticism is needed going forward. ", "author": "IHateUntruth", "created": 1773767337851, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "NoFats", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "We should reconsider the (mindlessly) pro-Trump policy here", "last_comment_created": 1773798773120, "content": "<p>This site currently requires that we be here to support MAGA and Trump.</p>\n<p>Supporting MAGA is a given. Requiring Trump support made complete sense when this website was vital in national elections and Trump was the candidate. That's done now, he got his two (three) terms.</p>\n<p>Why require it now?</p>\n<p>It's becoming increasingly clear that this administration and Trump personally are overly influenced by special interests that too often diverge from genuine America First principles - which is what most of us thought MAGA was about.</p>\n<p>To be clear, I still support Trump, but pretty lukewarmly. He's, obviously, much better than the alternative and I do not regret my votes and support. I will continue to defend him.</p>\n<p>But I'm also disappointed. Epstein files, slowrolled and backtracked deportations, lack of action on election fraud, lack of action against the deep state and other internal enemies, etc. The more-war-for-Israel thing isn't something I'm thrilled about either. I'm not as against it as many here, I don't particularly mind as long as we don't end up in something protracted with ground forces committed, I'd just rather see us not do the bidding of foreign powers with so many of our own problems remaining unsolved. Perhaps part of it is that Trump's scope for domestic action has been constrained by the treasonous GOP. But still.</p>\n<p>It's clear that we need a lot better in the future. He's probably the best we could have hoped for 2017-2029. He's the first stepping stone to securing our sovereignty but, obviously, not the end goal.</p>\n<p>At some point we have to let go of Trump. And this site at some point needs to transition. 2028 is coming. We need a more America First candidate. And we need to be able to talk critically.</p>\n<p>If anyone looks through major threads, Israel First shills are downvoted to oblivion and people critical of Trump right now get upvoted. So it's clear that many of us are already 'violating' the 'be here to support Trump' rule.</p>\n<p>I'm not suggesting that we turn <em>against</em> Trump. I'm saying that qualified support and open criticism is needed going forward.</p>\n", "score_down": 19, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 103, "score_up": 109, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASGIxp3Dj", "is_twitter": false, "is_admin": false, "score": 216, "suggested_sort": 0, "post_flair_class": "", "id": 8494177, "raw_content": "", "author": "rdvs34283", "created": 1773750052570, "profile_picture": "o9rQiLRpoh9n", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "MrTexan", "is_video": false, "video_link": "", "is_new_user": false, "domain": "justthenews.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASGIxp3Dj.png", "removal_source": "", "link": "https://justthenews.com/government/congress/gop-congressman-proposes-eliminating-capital-gains-tax-home-sales", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title"