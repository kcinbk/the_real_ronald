", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/2014488225310515201/MViNdHE3_normal.jpg", "displayName": "Matt Walsh", "username": "MattWalshBlog"}, "content": "There is no coherent argument against a blanket ban on all third world immigration. Nobody can explain how such a policy would harm the United States, because obviously it wouldn't. There is literally no downside. It's all upside. And we all know it.", "parentTweet": false, "likes": 26331}, "images": false, "linkEmbed": false, "replies": 11, "created": 1772398702000, "id": "2028213279902810377", "video": false, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/1906056188208328704/LOUoN9hY_normal.jpg", "displayName": "White Papers Policy Institute", "username": "WhitePapersPol"}, "content": "The ban on 3rs world immigration must be retroactive. ~90+ million 3rd worlders already live in the US.\n\nAmerica should be sending as many home as possible. The US needs a remigration policy.\n\nDenaturalized needs to become much easier and for a much wider variety of reasons.", "parentTweet": false, "likes": 1091}}, "post_flair_text": "\u00a0\u00a0\u00a0\u00a0\u00a0YES\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0", "archive_id": ""}, {"is_locked": false, "tweet_id": "2028187128728101082", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASG0Ir9Ah", "is_twitter": true, "is_admin": false, "score": 123, "suggested_sort": 0, "post_flair_class": "", "id": 8459563, "raw_content": "", "author": "kinbergfan", "created": 1772442001204, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Trump454748", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASG0Ir9Ah.png", "removal_source": "", "link": "https://twitter.com/seanmdav/status/2028187128728101082", "author_flair_