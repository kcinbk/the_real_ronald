 0, "post_flair_class": "", "id": 8525970, "raw_content": "", "author": "2Scoops2Terms2Walls", "created": 1774973421382, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "1_Badcop", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZ8KdfaC.png", "removal_source": "", "link": "https://twitter.com/i/status/2038977566413836309", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "A white firefighter saves the life of a black man who was overdosing on drugs. Later, when the firefighter asks if he has any firearms, the black man responds by shooting and killing him.\r\n\r\nWe can\u2019t live like this.", "last_comment_created": 1775004315423, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 39, "score_up": 468, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 225, "created": 1774965108000, "id": "2038977566413836309", "video": {"preview": "https://pbs.twimg.com/amplify_video_thumb/2038977447312478208/img/hrWffOvc8MGgeYz5.jpg", "mpeg": "https://video.twimg.com/amplify_video/2038977447312478208/pl/VB-cz7IL5fFMyYKv.m3u8?v=d3a", "aspectRatio": [15, 26], "heightRatio": 173, "type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2038977447312478208/vid/avc1/320x554/FwFYWI4ZHo9NY3OG.mp4"}, "poll": false, "user": {"profilePicture": "https://pbs.twimg.com/profile_images/2002188217592709120/sGNyKQ0O_normal.jpg", "displayName": "AshleY", "username": "Aku_700"}, "content": "A white firefighter saves the life of a black man who was overdosing on drugs. Later, when the firefighter asks if he has any firearms, the black man responds by shooting and killing him.\n\nWe can\u2019t live like this.", "parentTweet": false, "likes": 4298}}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZ8Kc1QM", "is_twitter": false, "is_admin": false, "score": 1137, "suggested_sort": 0, "post_flair_class": "yes", "id": 8525396, "raw_content": "", "author": "dirtysanchez69", "created": 1774955828428, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Maganifice7", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZ8Kc1QM.png", "removal_source": "", "link": "https://media.scored.co/post/CapnhZCsy2p7.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/NG0iogxWTaQ8S8OZ.jpeg", "width": 374, "content-type": "jpeg", "height": 768}], "blurhash": "U2Ss50009F~qIUWBWBWBxuxu-;ay~qM{Rjay", "full_resolution": [945, 460]}, "title": "Aren't we all?", "last_comment_created": 1774997477101, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 127, "score_up": 1137, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "\u00a0\u00a0\u00a0\u00a0\u00a0YES\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASZ8Kd71I", "is_twitter": false, "is_admin": false, "score": 629, "suggested_sort": 0, "post_flair_class": "", "id": 8525704, "raw_content": "This past Friday, as I'm recovering from double mastectomy, my mom died in the hospital. She had been admitted to the hospital the day before I went in for surgery, was in the hospital for 9 days. On the 9th day the doctors attempted to place stents in her heart which had 4 blockages. She had declined open heart surgery and agreed to this procedure knowing she might not survive it. She was ready. Her last few years of life have been harder than anyone should have to live due to lower back issues. She had essentially been bedridden for the last year. \n\nI feel lost. Over the years I've wondered how I would feel when my mom was gone. I knew it would be hard and it is but I'm comforted that she is no longer in pain.. She did everything she could to help me during my breast cancer treatment, even to the detriment of her own physical health. My mom was always there for me and I will miss her presence until the day I die. \n\nMy family is truly going through some of the worst times in these last few years. Trying times. Difficult to navigate. My faith is tested more and more and with those tests I become more convicted in my faith. \n\nIf you still have your mom hug her every chance you can. When she's gone, you don't get it back. \n\nWhen your family gets hit over and over again, as mine has been, politics no longer matter. Love your family and be with them while you can. ", "author": "ChickNorris", "created": 1774966811159, "profile_picture": "Qe8wSmir2i1S", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Watermelons", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "So my mom died", "last_comment_created": 1775004997329, "content": "<p>This past Friday, as I'm recovering from double mastectomy, my mom died in the hospital. She had been admitted to the hospital the day before I went in for surgery, was in the hospital for 9 days. On the 9th day the doctors attempted to place stents in her heart which had 4 blockages. She had declined open heart surgery and agreed to this procedure knowing she might not survive it. She was ready. Her last few years of life have been harder than anyone should have to live due to lower back issues. She had essentially been bedridden for the last year.</p>\n<p>I feel lost. Over the years I've wondered how I would feel when my mom was gone. I knew it would be hard and it is but I'm comforted that she is no longer in pain.. She did everything she could to help me during my breast cancer treatment, even to the detriment of her own physical health. My mom was always there for me and I will miss her presence until the day I die.</p>\n<p>My family is truly going through some of the worst times in these last few years. Trying times. Difficult to navigate. My faith is tested more and more and with those tests I become more convicted in my faith.</p>\n<p>If you still have your mom hug her every chance you can. When she's gone, you don't get it back.</p>\n<p>When your family gets hit over and over again, as mine has been, politics no longer matter. Love your family and be with them while you can.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 139, "score_up": 629, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZ8LlmrB", "is_twitter": false, "is_admin": false, "score": 130, "suggested_sort": 0, "post_flair_class": "", "id": 8526849, "raw_content": "", "author": "Crucible", "created": 1774997207574, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "TrumpVoter1", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZ8LlmrB.png", "removal_source": "", "link": "https://media.scored.co/post/AtF7MUNxXmhG.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/9dODhI1x2AYKvBVD.png", "width": 768, "content-type": "png", "height": 757}], "blurhash": "U4FhV90000~q00^*rX-p*^^*X:Vq01%g^%Q-", "full_resolution": [1152, 1168]}, "title": "Okay, last one. I swear it. Then I'm out. ", "last_comment_created": 1775006078709, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 17, "score_up": 130, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}], "status": true}