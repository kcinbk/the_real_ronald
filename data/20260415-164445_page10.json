0}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZQzaT6V", "is_twitter": false, "is_admin": false, "score": 112, "suggested_sort": 0, "post_flair_class": "", "id": 8560137, "raw_content": "", "author": "AslanFan", "created": 1776249102318, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "", "is_video": false, "video_link": "", "is_new_user": false, "domain": "media.scored.co", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZQzaT6V.png", "removal_source": "", "link": "https://media.scored.co/post/L6h7cNxdnhXl.jpeg", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [{"reference": "/scale/OPmUM5p5Y06HscIR.png", "width": 768, "content-type": "png", "height": 637}], "blurhash": "U$KnYot7t8of-;a}WBay~qWBWAayM{oKaxWB", "full_resolution": [996, 1200]}, "title": "Defiant Trump nails \"Art of the Deal\" to the Vatican door", "last_comment_created": 1776249102316, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": true, "comments": 0, "score_up": 112, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "", "sticky_comment": 0, "is_video_mp4": false, "type": "text", "uuid": "1ASZQzcflJ", "is_twitter": false, "is_admin": false, "score": 19, "suggested_sort": 0, "post_flair_class": "stable", "id": 8560979, "raw_content": "Let's be real: Trump clashing with Pope Francis isn't the political disaster some people make it out to be\u2014it\u2019s actually a brilliant, calculated move.\n\nThere is a deep, growing fracture within the Catholic Church, especially here in the United States. A significant portion of conservative and traditional Catholics are deeply alienated by the current papacy's progressive direction. You don't have to look any further than the situation with Archbishop Carlo Maria Vigan\u00f2. His fierce, vocal opposition to Rome\u2014and his subsequent excommunication\u2014highlighted just how wide the gap has become between traditional American Catholics and the current Vatican leadership.\n\nBy pushing back against the Pope, Trump is tapping directly into this exact demographic. He isn't losing the Catholic vote; he's specifically aligning himself with the highly motivated, traditionalist wing of the Church. These voters feel completely abandoned by the Vatican's current trajectory on cultural and social issues.\n\nWhen Trump stands his ground against the papacy, he steps into the vacuum and positions himself as the defender of the conservative values they care about most. It\u2019s a bold move that capitalizes on an already existing religious divide to lock down a crucial, passionate voting bloc.\n\nTrump should meet with Vigan\u00f2 to light the fire even more.", "author": "NSFW_PORN_ONLY", "created": 1776282656278, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "MocksFordComma", "is_video": false, "video_link": "", "is_new_user": false, "domain": "", "is_crosspost": false, "preview": "", "removal_source": "", "link": "", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "Why Trump clashing with the Pope is actually a massive strategic advantage.", "last_comment_created": 1776285694994, "content": "<p>Let's be real: Trump clashing with Pope Francis isn't the political disaster some people make it out to be\u2014it\u2019s actually a brilliant, calculated move.</p>\n<p>There is a deep, growing fracture within the Catholic Church, especially here in the United States. A significant portion of conservative and traditional Catholics are deeply alienated by the current papacy's progressive direction. You don't have to look any further than the situation with Archbishop Carlo Maria Vigan\u00f2. His fierce, vocal opposition to Rome\u2014and his subsequent excommunication\u2014highlighted just how wide the gap has become between traditional American Catholics and the current Vatican leadership.</p>\n<p>By pushing back against the Pope, Trump is tapping directly into this exact demographic. He isn't losing the Catholic vote; he's specifically aligning himself with the highly motivated, traditionalist wing of the Church. These voters feel completely abandoned by the Vatican's current trajectory on cultural and social issues.</p>\n<p>When Trump stands his ground against the papacy, he steps into the vacuum and positions himself as the defender of the conservative values they care about most. It\u2019s a bold move that capitalizes on an already existing religious divide to lock down a crucial, passionate voting bloc.</p>\n<p>Trump should meet with Vigan\u00f2 to light the fire even more.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 10, "score_up": 19, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "\ud83e\udde0\u00a0\u00a0STABLE GENIUS\u00a0\u00a0\ud83e\udde0", "archive_id": ""}], "status": true}