isan observers.</p>\n", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 20, "score_up": 460, "is_edited": true, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"status": 200}, "post_flair_text": "", "archive_id": ""}, {"is_locked": false, "tweet_id": "2046846602674102365", "sticky_comment": 0, "is_video_mp4": false, "type": "link", "uuid": "1ASZVlvy12", "is_twitter": true, "is_admin": false, "score": 234, "suggested_sort": 0, "post_flair_class": "", "id": 8575248, "raw_content": "", "author": "kek_saved_the_world", "created": 1776902455517, "profile_picture": "", "community": "TheDonald", "ad_tier": 2, "last_comment_author": "Advhawk", "is_video": false, "video_link": "", "is_new_user": false, "domain": "twitter.com", "is_crosspost": false, "preview": "https://media.scored.co/preview/1ASZVlvy12.png", "removal_source": "", "link": "https://twitter.com/WHLeavitt/status/2046846602674102365", "author_flair_class": "", "is_removed": false, "media": {"resized_resolutions": [], "blurhash": "", "full_resolution": []}, "title": "RORBERT BASED!!!", "last_comment_created": 1776931995147, "content": "", "score_down": 0, "author_flair_text": "", "pro_tier": 0, "is_stickied": false, "is_nsfw": false, "is_deleted": false, "is_image": false, "comments": 10, "score_up": 234, "is_edited": false, "is_moderator": false, "awards": 0, "vote_state": 2, "link_metadata": {"twitter": {"quotedTweet": false, "images": false, "linkEmbed": false, "replies": 1559, "created": 1776841233000, "id": "2046846602674102365", "video": {"preview": "https://pbs.twimg.com/amplify_video_thumb/2046846520813842432/img/qHDYAh1MSwW81Lsb.jpg", "mpeg": "https://video.twimg.com/amplify_video/2046846520813842432/pl/aQEdQYmeWG4TKqk9.m3u8?v=dc5", "aspectRatio": [9, 16], "heightRatio": 177, "type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2046846520813842432/vid/avc1/320x568/Gszr